const articleList = articles.filter(Boolean);
const bySlug = Object.fromEntries(articleList.map((article) => [article.slug, article]));

const slugFromHref = (href = '') => {
  const match = String(href).match(/\/txt\/([^/]+)\/?/);
  return match?.[1] ?? '';
};

const articleTitle = (href = '', fallback = '') => {
  const slug = slugFromHref(href);
  return bySlug[slug]?.title ?? fallback;
};

const formatInline = (value = '') => {
  return String(value)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/&lt;(\/?)(s|del)&gt;/gi, '<$var(--motion-word)>')
    .replace(/&lt;(\/?)(em|i)&gt;/gi, '<$1em>')
    .replace(/~~([^~]+)~~/g, '<s>$1</s>');
};

