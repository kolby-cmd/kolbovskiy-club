          { no: '04', title: 'SIGGRAPH 24', note: 'Красивое — картинки (мои) с выставки в Денвере.', rubrics: 'КРАСИВОЕ', readTime: 'выставка', href: '/txt/siggraph-24/' }
        ]
      },
      {
        name: '<em>Bonus-tracks</em>',
        lead: '<em>В каждой шутке есть доля шутки</em> — всякое веселое, на чем отдыхаю. <em>Raw-формат</em> проецируется на мою сетчатку с обратной стороны сразу цельным куском текста, не редактируется.',
        items: [
          { no: '05', title: 'Черта характера', note: 'Короткий raw-этюд о том, как личная деформация внезапно оказывается не дефектом, а рабочим способом держаться в реальности.', rubrics: 'НАМОЛНИИ', readTime: 'raw', href: '/txt/character-trait/' },
          { no: '06', title: 'Осенняя профориентация', note: 'Профориентационный приступ на стыке усталости, самоиронии и взрослого вопроса: чем вообще заниматься, если обычные ответы уже не работают.', rubrics: 'WIMM', readTime: 'raw', href: '/txt/autumn-career-guidance/' },
          { no: '07', title: 'Невольные свидетельства', note: 'Маленькая фиксация чужих симптомов времени: смешно ровно до момента, когда понимаешь, что свидетельства обычно невольные у всех.', rubrics: 'НАМОЛНИИ', readTime: 'raw', href: '/txt/involuntary-testimonies/' }
        ]
      }
    ]
  }
];

const otherAlbums = albums.slice(1);
const jsonLd = buildJsonLdGraph({
  '@type': 'CollectionPage',
  '@id': `${pageCanonical}#webpage`,
  name: pageTitle,
  description: pageDescription,
  url: pageCanonical,
  inLanguage: 'ru',
  isPartOf: { '@id': KOLBOVSKIY_CLUB_WEBSITE_ID },
  author: { '@id': KOLBOVSKIY_PERSON_ID },
  publisher: { '@id': KOLBOVSKIY_PERSON_ID },
  image: `https://kolbovskiy.club${pageOgImage}`,
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: albums.length,
    itemListElement: albums.map((album, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: `${album.issue} — ${album.title}`,
      url: `${pageCanonical}#${album.id}`
    }))
  }
});
---

<SiteLayout title={pageTitle} description={pageDescription} canonical={pageCanonical} ogImage={pageOgImage} current="best" jsonLd={jsonLd}>
  <main class="best-page">
    <section class="best-hero" aria-labelledby="best-title">
      <div class="best-hero-top">
        <div class="best-brow"><span class="dot dot-pulse"></span><span>Greatest Hi[ea]ts</span></div>
        <h1 id="best-title" class="best-title">колба</h1>
      </div>
      <div class="best-hero-bottom">
        <p class="best-lede">Дистилляты лучших материалов. Периодические выпуски, ручные подшивки текстов по внутренней связи. Альбомы из наблюдений, рынков, городов, дизайна и сбоев Реального мира.</p>
        <aside class="best-counter" aria-label="Счётчик выпусков">
          <span class="best-counter-label">выпусков</span>
          <span class="best-counter-num">04</span>
          <span class="best-counter-sub">колба</span>
        </aside>
      </div>
    </section>

    <section class="featured-album" id={featured.id} aria-labelledby="featured-title">
      <div class="featured-grid">
        <figure class="album-cover album-cover--large album-cover--image cover-03" aria-label="Обложка сборника">
          <img src={featured.coverImage} alt="" loading="eager" decoding="async" />
        </figure>

        <article class="album-main album-main--featured">
          <div class="album-meta"><span>{featured.issue}</span><span>{featured.season}</span><span>{featured.date}</span></div>
          <div class="album-title-row">
            <h3 id="featured-title">{featured.title}</h3>
            <span class="album-count"><b>{featured.count}</b><span>материалов</span></span>
          </div>
          <p set:html={formatInline(featured.lead)}></p>

          <div class="side-list">
            {featured.sides.map((side) => (
              <section class="album-side">
                <h4 set:html={formatInline(side.name)}></h4>
                {side.lead && <p class="side-lead" set:html={formatInline(side.lead)}></p>}
                <div class="tracklist">
                  {side.items.map((item) => (
                    <>
                      <a
                        class="track-row"
                        href={item.href}
                        target={item.href.startsWith('http') ? '_blank' : undefined}
                        rel={item.href.startsWith('http') ? 'noreferrer' : undefined}
                      >
                        <span class="track-no">{item.no}</span>
                        <span class="track-title"><b>{articleTitle(item.href, item.title)}</b><em set:html={formatInline(item.note)}></em></span>
                        <span class="track-rubrics">{item.rubrics}</span>
                        <span class="track-time">{item.readTime}</span>
                        <span class="track-go" aria-hidden="true"></span>
                      </a>
                      {item.extraHref && (
                        <a class="track-extra" href={item.extraHref} target="_blank" rel="noreferrer">
                          {item.extraLabel || 'продолжение'}
                        </a>
                      )}
                    </>
                  ))}
                </div>
              </section>
            ))}
          </div>

          <div class="featured-album-outro">
            <p>
              {featured.outroStart}<a href="https://kolbovskiy.club/" target="_blank" rel="noreferrer">отдельный нарядный сайт</a>{featured.outroMiddle}<em><a href="https://youtu.be/aWhRXnnETQo?si=IoGU2kwqbZYc8TeL" target="_blank" rel="noreferrer">Руля, как такового,</a>{featured.outroEnd}</em>
            </p>
          </div>
        </article>
      </div>
    </section>

    <section class="album-archive" aria-labelledby="album-archive-title">
      <div class="best-section-head best-section-head--archive">
        <div>
          <h2 id="album-archive-title">Все выпуски</h2>
          <p>Архив выпусков «Колбы»: квартальные и полевые дистилляты, собранные вручную.</p>
        </div>
        <button class="expand-all" type="button" data-expand-albums>[Развернуть все]</button>
      </div>

      <div class="album-details-list">
        {otherAlbums.map((album, index) => (
          <details class="album-detail" id={album.id}>
            <summary>
              <span class={`album-cover album-cover--small ${album.coverImage ? 'album-cover--image' : ''} cover-0${2 - index}`} aria-hidden="true">
                {album.coverImage ? (
                  <img src={album.coverImage} alt="" loading="lazy" decoding="async" />
                ) : (
                  <span class="cover-tag">GH-{String(2 - index).padStart(2, '0')}</span>
                )}
              </span>
              <span class="summary-main">
                <span class="summary-issue">{album.issue} · {album.season}</span>
                <b>{album.title}</b>
                <em set:html={formatInline(album.lead)}></em>
              </span>
              <span class="summary-count"><b>{album.count}</b><span>материалов</span></span>
              <span class="summary-mark" aria-hidden="true"></span>
            </summary>
            <div class="detail-body featured-grid">
              <figure class={`album-cover album-cover--large ${album.coverImage ? 'album-cover--image' : ''} cover-0${2 - index}`} aria-label={`Обложка ${album.issue}`}>
                {album.coverImage ? (
                  <img src={album.coverImage} alt="" loading="lazy" decoding="async" />
                ) : (
                  <>
                    <span class="cover-tag">GH-{String(2 - index).padStart(2, '0')}</span>
                    <span class="cover-name">Greatest<br />Hi[ea]ts</span>
                    <span class="cover-season">{album.season}</span>
                  </>
                )}
              </figure>

              <article class="album-main">
                <div class="album-meta"><span>{album.issue}</span><span>{album.season}</span><span>{album.date}</span></div>
                <div class="album-title-row">
                  <h3>{album.title}</h3>
                  <span class="album-count"><b>{album.count}</b><span>материалов</span></span>
                </div>
                {album.body ? (
                  <div class="album-copy">
                    {album.body.map((paragraph) => <p set:html={formatInline(paragraph)}></p>)}
                  </div>
                ) : (
                  <p set:html={formatInline(album.lead)}></p>
                )}

                {album.sides ? (
                  <div class="side-list">
                    {album.sides.map((side) => (
                      <section class="album-side">
                        <h4 set:html={formatInline(side.name)}></h4>
                        {side.lead && <p class="side-lead" set:html={formatInline(side.lead)}></p>}
                        <div class="tracklist tracklist--compact">
                          {side.items.map((item) => (
                            <>
                              <a
                                class="track-row"
                                href={item.href}
                                target={item.href.startsWith('http') ? '_blank' : undefined}
                                rel={item.href.startsWith('http') ? 'noreferrer' : undefined}
                              >
                                <span class="track-no">{item.no}</span>
                                <span class="track-title"><b>{articleTitle(item.href, item.title)}</b><em set:html={formatInline(item.note)}></em></span>
                                <span class="track-rubrics">{item.rubrics}</span>
                                <span class="track-time">{item.readTime}</span>
                                <span class="track-go" aria-hidden="true"></span>
                              </a>
                              {item.extraHref && (
                                <a class="track-extra" href={item.extraHref} target="_blank" rel="noreferrer">
                                  {item.extraLabel || 'продолжение'}
                                </a>
                              )}
                            </>
                          ))}
                        </div>
                      </section>
                    ))}
                  </div>
                ) : (
                  <div class="side-list">
                    <section class="album-side">
                      <h4>Tracklist</h4>
                      <div class="tracklist tracklist--compact">
                        {album.items.map((item) => (
                          <a
                            class="track-row"
                            href={item.href}
                            target={item.href.startsWith('http') ? '_blank' : undefined}
                            rel={item.href.startsWith('http') ? 'noreferrer' : undefined}
                          >
                            <span class="track-no">{item.no}</span>
                            <span class="track-title"><b>{articleTitle(item.href, item.title)}</b><em set:html={formatInline(item.note)}></em></span>
                            <span class="track-rubrics">{item.rubrics}</span>
                            <span class="track-time">{item.readTime}</span>
                            <span class="track-go" aria-hidden="true"></span>
                          </a>
                        ))}
                      </div>
                    </section>
                  </div>
                )}

                {album.notes && (
                  <div class="detail-notes">
                    {album.notes.map((note) => (
                      <section class="detail-note">
                        <span>{note.title}</span>
                        <p set:html={formatInline(note.text)}></p>
                      </section>
                    ))}
                  </div>
                )}
              </article>
            </div>
          </details>
        ))}
      </div>
    </section>

    <nav class="best-nav" aria-label="Навигация">
      <a href="/archive/"><span>В бездну</span><i aria-hidden="true"></i></a>
      <a href="/rubrics/"><span>К рубрикам</span><i aria-hidden="true"></i></a>
    </nav>
  </main>

  <script>
    (() => {
      const button = document.querySelector('[data-expand-albums]');
      const details = Array.from(document.querySelectorAll('.album-detail'));
      if (!button || !details.length) return;

      button.addEventListener('click', () => {
        const shouldOpen = details.some((item) => !item.open);
        details.forEach((item) => { item.open = shouldOpen; });
        button.textContent = shouldOpen ? '[Свернуть все]' : '[Развернуть все]';
      });
    })();
  </script>
</SiteLayout>

<style>
  :global(s) {
    text-decoration: line-through;
    text-decoration-thickness: 0.09em;
    text-decoration-color: currentColor;
  }

  :global(em) {
    font-style: italic;
  }


  .track-title s,
  .album-copy s,
  .side-lead s,
  .detail-note s,
  .summary-main s {
    text-decoration: line-through;
    text-decoration-thickness: 0.08em;
    text-decoration-color: var(--red);
    text-underline-offset: 0.12em;
  }


  .album-side h4 em {
    font-style: italic;
  }

  .track-title > em em,
  .side-lead em,
  .album-copy em,
  .detail-note em,
  .summary-main em {
    display: inline;
    margin: 0;
    color: inherit;
    font-size: inherit;
    line-height: inherit;
    font-style: italic;
  }

  .track-title > em s,
  .side-lead s,
  .album-copy s,
  .detail-note s,
  .summary-main s {
    color: inherit;
  }

  .best-page {
    --best-header: 58px;
    --body-bleed: 0px;
    margin-top: calc(-1 * var(--best-header));
    background: var(--white);
    color: var(--black);
    min-height: 100svh;
  }

  .best-hero {
    padding-left: var(--pad);
    padding-right: var(--pad);
  }

  .featured-album,
  .album-archive {
    width: min(1180px, calc(100% - var(--pad) * 2));
    margin-inline: auto;
    padding-left: 0;
    padding-right: 0;
  }

  .best-hero {
    padding-top: calc(var(--best-header) + clamp(64px, 7.4vh, 96px));
    padding-bottom: clamp(30px, 5vh, 58px);
    border-bottom: 1px solid var(--black);
  }

  .best-brow {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: clamp(22px, 3vh, 34px);
    color: var(--red);
    font-family: var(--font-ui);
    font-size: 11px;
    line-height: 1;
    letter-spacing: .22em;
    text-transform: uppercase;
  }

  .best-hero-top {
    display: block;
  }

  .best-hero-bottom {
    display: grid;
    grid-template-columns: minmax(0, 1fr) clamp(260px, 23vw, 340px);
    gap: clamp(32px, 6vw, 96px);
    align-items: end;
    margin-top: clamp(6px, .9vw, 14px);
  }

  .best-title {
    margin: 0;
    color: var(--red);
    font-family: var(--font-display);
    font-size: clamp(92px, 11vw, 168px);
    font-weight: 400;
    line-height: .82;
    letter-spacing: -.025em;
    text-transform: uppercase;
  }

  .best-lede {
    width: min(720px, 100%);
    max-width: 720px;
    margin: 0;
    color: var(--black);
    font-family: var(--font-ui);
    font-size: clamp(16px, 1.15vw, 18px);
    line-height: 1.72;
    letter-spacing: .01em;
  }

  .best-counter {
    align-self: end;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    padding: 18px 0 14px;
    font-family: var(--font-ui);
    text-transform: uppercase;
  }

  .best-counter-label,
  .best-counter-sub {
    display: block;
    color: var(--gray);
    font-size: 10px;
    line-height: 1;
    letter-spacing: .18em;
  }

  .best-counter-num {
    display: block;
    margin: 10px 0 12px;
    color: var(--red);
    font-family: var(--font-display);
    font-size: clamp(58px, 5vw, 82px);
    line-height: .86;
    letter-spacing: -.01em;
  }

  .featured-album,
  .album-archive {
    padding-top: clamp(62px, 8vw, 110px);
    padding-bottom: clamp(60px, 8vw, 110px);
  }

  .featured-album {
    border-bottom: 1px solid var(--black);
  }

  .album-archive {
    border-bottom: 0;
  }

  .best-section-head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 28px;
    align-items: end;
    margin-bottom: clamp(28px, 4vw, 48px);
  }

  .section-num { display: none; }

  .best-section-head h2 {
    margin: 0;
    color: var(--black);
    font-family: var(--font-display);
    font-size: clamp(54px, 6vw, 82px);
    font-weight: 400;
    line-height: .9;
    letter-spacing: -.018em;
    text-transform: uppercase;
  }

  .best-section-head p {
    max-width: 520px;
    margin: 14px 0 0;
    color: var(--gray);
    font-family: var(--font-ui);
    font-size: 14px;
    font-style: italic;
    line-height: 1.55;
  }

  .section-count {
    display: grid;
    justify-items: end;
    gap: 4px;
    color: var(--gray);
    font-family: var(--font-ui);
    font-size: 10px;
    letter-spacing: .18em;
    text-transform: uppercase;
  }

  .section-count b {
    color: var(--red);
    font-family: var(--font-display);
    font-size: clamp(48px, 4.4vw, 70px);
    font-weight: 400;
    line-height: .86;
    letter-spacing: -.01em;
  }

  .featured-grid {
    display: grid;
    grid-template-columns: minmax(300px, 420px) minmax(0, 1fr);
    gap: clamp(34px, 4.2vw, 56px);
    align-items: start;
  }

  .album-cover {
    position: relative;
    display: block;
    overflow: hidden;
    border: 1px solid var(--black);
    background: var(--soft);
    isolation: isolate;
  }

  .album-cover:before,
  .album-cover:after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .album-cover:before {
    background:
      radial-gradient(circle at 24% 30%, rgba(209, 11, 11, .36), transparent 30%),
      radial-gradient(circle at 78% 70%, rgba(10, 10, 9, .18), transparent 34%),
      linear-gradient(135deg, rgba(240,237,230,.92), rgba(230,226,214,.6));
  }

  .album-cover:after {
    opacity: .36;
    background:
      repeating-linear-gradient(0deg, rgba(10,10,9,.12) 0 1px, transparent 1px 18px),
      repeating-linear-gradient(90deg, rgba(10,10,9,.08) 0 1px, transparent 1px 18px);
    mix-blend-mode: multiply;
  }

  .album-cover img {
    position: absolute;
    inset: 0;
    z-index: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .album-cover--image:before {
    z-index: 1;
    background: linear-gradient(180deg, rgba(240, 237, 230, .08), rgba(10, 10, 9, .2));
    mix-blend-mode: multiply;
  }

  .album-cover--image:after {
    z-index: 1;
    opacity: .2;
  }

  .cover-03:before { background: radial-gradient(circle at 28% 28%, rgba(209,11,11,.5), transparent 32%), radial-gradient(circle at 74% 72%, rgba(240,150,85,.42), transparent 38%), linear-gradient(145deg, #f0ede6 0%, #dfd6c4 100%); }
  .album-cover--image.cover-03:before,
  .album-cover--image.cover-03:after,
  .album-cover--image.cover-02:before,
  .album-cover--image.cover-02:after,
  .album-cover--image.cover-01:before,
  .album-cover--image.cover-01:after,
  .album-cover--image.cover-00:before,
  .album-cover--image.cover-00:after {
    display: none;
  }
  .cover-02:before { background: radial-gradient(circle at 70% 25%, rgba(209,11,11,.42), transparent 30%), radial-gradient(circle at 22% 74%, rgba(80,90,120,.34), transparent 38%), linear-gradient(145deg, #ebe6d9 0%, #d6d0c2 100%); }
  .cover-01:before { background: radial-gradient(circle at 30% 70%, rgba(209,11,11,.48), transparent 32%), radial-gradient(circle at 78% 24%, rgba(210,140,70,.34), transparent 34%), linear-gradient(145deg, #f0ede6 0%, #ded4bf 100%); }
  .cover-00:before { background: radial-gradient(circle at 52% 40%, rgba(209,11,11,.42), transparent 34%), radial-gradient(circle at 15% 82%, rgba(10,10,9,.22), transparent 38%), linear-gradient(145deg, #ebe6d9 0%, #d9d3c4 100%); }

  .album-cover--large {
    width: 100%;
    aspect-ratio: 1 / 1;
  }

  .album-cover--small {
    width: 84px;
    height: 84px;
    flex: 0 0 84px;
  }

  .cover-tag,
  .cover-season,
  .cover-name {
    position: absolute;
    z-index: 2;
    font-family: var(--font-ui);
    text-transform: uppercase;
  }

  .cover-tag {
    top: 16px;
    left: 16px;
    color: var(--red);
    font-size: 10px;
    line-height: 1;
    letter-spacing: .22em;
  }

  .cover-name {
    left: 16px;
    bottom: 42px;
    color: var(--black);
    font-weight: 700;
    font-size: clamp(18px, 2.2vw, 32px);
    line-height: .95;
    letter-spacing: .02em;
  }

  .cover-season {
    right: 16px;
    bottom: 16px;
    color: var(--gray);
    font-size: 10px;
    line-height: 1;
    letter-spacing: .18em;
  }

  .album-cover--small .cover-tag {
    top: 8px;
    left: 8px;
    font-size: 8px;
    letter-spacing: .14em;
  }

  .album-main {
    border-top: 1px solid var(--black);
  }

  .album-meta {
    display: grid;
    grid-template-columns: 1fr auto auto;
    gap: 18px;
    padding: 14px 0;
    border-bottom: 1px solid var(--line);
    color: var(--gray);
    font-family: var(--font-ui);
    font-size: 10px;
    line-height: 1;
    letter-spacing: .16em;
    text-transform: uppercase;
  }

  .album-meta span:first-child {
    color: var(--red);
    font-weight: 700;
  }

  .album-title-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 24px;
    align-items: end;
    margin: clamp(24px, 3vw, 38px) 0 16px;
  }

  .album-main h3 {
    max-width: 720px;
    margin: 0;
    color: var(--black);
    font-family: var(--font-display);
    font-size: clamp(40px, 5vw, 82px);
    font-weight: 400;
    line-height: .92;
    letter-spacing: -.018em;
    text-transform: uppercase;
  }

  .album-count {
    display: grid;
    justify-items: end;
    gap: 3px;
    color: var(--gray);
    font-family: var(--font-ui);
    font-size: 9px;
    line-height: 1;
    letter-spacing: .14em;
