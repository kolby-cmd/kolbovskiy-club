---
import { buildJsonLdGraph, KOLBOVSKIY_CLUB_WEBSITE_ID, KOLBOVSKIY_DIGITAL_BODY_ID, KOLBOVSKIY_PERSON_ID } from '../data/siteEntity';
import { articles } from '../data/articles';

const siteUrl = 'https://kolbovskiy.club';
const siteTitle = 'kolbovskiy.club — частное медиа о сложных системах и неопределённости';
const siteDescription = 'Авторское издание Никиты Колбовского о реальном мире: технологиях, рынках, власти, культуре, архитектуре, путешествиях и сбоях системы.';
const siteCanonical = `${siteUrl}/`;
const siteOgImage = `${siteUrl}/og/kolbovskiy-club.jpg`;
const webSiteJsonLd = buildJsonLdGraph({
  '@type': 'WebPage',
  '@id': `${siteCanonical}#webpage`,
  name: siteTitle,
  description: siteDescription,
  url: siteCanonical,
  inLanguage: 'ru',
  isPartOf: { '@id': KOLBOVSKIY_CLUB_WEBSITE_ID },
  about: { '@id': KOLBOVSKIY_DIGITAL_BODY_ID },
  author: { '@id': KOLBOVSKIY_PERSON_ID },
  publisher: { '@id': KOLBOVSKIY_PERSON_ID },
  primaryImageOfPage: siteOgImage
});

const articleList = articles.filter(Boolean);
const bySlug = Object.fromEntries(articleList.map((article) => [article.slug, article]));
const byDateDesc = [...articleList].sort((a, b) => new Date(b.datetime).getTime() - new Date(a.datetime).getTime());
const articleHref = (article) => `/txt/${article.slug}/`;
const stripHtml = (value = '') => value.replace(/<br\s*\/?>/gi, ' ').replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();
const formatRubric = (rubric = '') => rubric.replace('#', '');
const formatRubrics = (article) => article.rubrics.map(formatRubric).join(' / ');
const topicsLine = (article) => article.topics.slice(0, 3).join(' / ') || article.rubrics.map(formatRubric).join(' / ');
const deckText = (article) => stripHtml(article.deckHtml);
const imageFocusY = (article) => {
  const focus = {
    'genius-act-1': '42%',
    'liquidation-of-greed': '44%',
    'think-there-is-water': '38%',
    'alaska': '48%',
    'price-of-the-image': '52%',
    'radisson-blu': '50%',
    'f1': '44%',
    'limits-of-permission': '50%',
    'information': '44%',
    'zakatnoe': '52%',
    'tea-with-elephant': '42%',
    'put-the-stone': '52%',
    'six-herons': '50%',
    'shabash': '42%',
    'yustas': '46%',
    'homeland': '46%',
    'perfectionism-inc': '50%',
    'na-iznos': '42%',
    'khoroshaya': '42%',
    'siggraph-24': '50%',
    'edge-of-the-world-4k': '50%'
  };

  return focus[article.slug] ?? '50%';
};

const heroToneVars = (article) => {
  const tone = {
    'genius-act-1': {
      sideA: '.28',
      sideB: '.36',
      topA: '.06',
      midA: '.00',
      bottomA: '.30'
    },
    bright: {
      sideA: '.52',
      sideB: '.62',
      topA: '.20',
      midA: '.08',
      bottomA: '.54'
    },
    default: {
      sideA: '.36',
      sideB: '.46',
      topA: '.12',
      midA: '.03',
      bottomA: '.38'
    }
  };

  const brightSlugs = new Set([
    'liquidation-of-greed',
    'f1',
    'limits-of-permission',
    'shabash',
    'na-iznos'
  ]);

  const value = tone[article.slug] ?? (brightSlugs.has(article.slug) ? tone.bright : tone.default);

  return `--hero-side-a:${value.sideA};--hero-side-b:${value.sideB};--hero-top-a:${value.topA};--hero-mid-a:${value.midA};--hero-bottom-a:${value.bottomA}`;
};


const featuredArticle = bySlug['edge-of-the-world-4k'] ?? bySlug['genius-act-1'] ?? byDateDesc[0];
const heroTitle = featuredArticle.title.toUpperCase().replace(/\s+/g, '\u00A0');
const heroCaptionHtml = [featuredArticle.deckHtml, featuredArticle.description].filter(Boolean).join('<br>');
const freshArticles = byDateDesc.filter((article) => Boolean(article.heroImage)).slice(0, 4);
const archivePreview = byDateDesc.slice(0, 5);
const searchIndex = articleList.map((article) => {
  const deck = deckText(article);
  const rubrics = article.rubrics ?? [];
  const topics = article.topics ?? [];
  const body = Array.isArray(article.body) ? article.body.map(stripHtml).join(' ') : '';

  return {
    issue: article.issue,
    rubric: rubrics[0]?.replace('#', '') ?? 'архив',
    label: deck ? `${article.title} / ${deck}` : article.title,
    href: articleHref(article),
    haystack: [
      article.issue,
      article.title,
      deck,
      article.description,
      article.excerpt,
      article.thesis,
      rubrics.join(' '),
      topics.join(' '),
      body
    ].filter(Boolean).join(' ')
  };
});
const searchSuggestions = searchIndex.slice(0, 5);

const archiveTotal = articleList.length;
const kolbaVolumes = [
  { id: 'greatest-hieats-03', no: '03', title: 'Первый квартал второго сезона', coverImage: '/images/best/GH_cv_003.jpg', desc: 'Акт Гения, Футурологический конгресс, Ликвидация, Аляска, Цена картинки, Рэдиссон, F-1 и ещё несколько нервных материалов сезона.', count: '11 материалов' },
  { id: 'greatest-hieats-02', no: '02', title: 'Каналу год', coverImage: '/images/best/GH_cv_002.jpg', desc: 'Год каналу: Лебедьрак Ищука 2.0, Информация, Чай со слоном, Homeland, Perfectionism Inc, На износ и Каба.', count: '11 материалов' },
  { id: 'greatest-hieats-01', no: '01', title: 'Сюжетики ого-го, как у A24', coverImage: '/images/best/GH_cv_001.jpg', desc: 'Лебедьрак Ищука 1.0, биткоин, Тайвань, Shutdown /r, Миллиарды, Хорошая, шутки и Вилли.', count: '12 материалов' },
  { id: 'greatest-hieats-00', no: '00', title: 'Наконец, накопил', coverImage: '/images/best/GH_cv_000.jpg', desc: 'Буллран, Лебедьрак Ищука 0, Homo Orchestra, SIGGRAPH 24, Черта характера, профориентация и невольные свидетельства.', count: '7 материалов' }
];
const kolbaLeadSlugs = ['genius-act-1', 'futurological-congress-1', 'liquidation-of-greed'];
const kolbaLeadArticles = kolbaLeadSlugs.map((slug) => bySlug[slug]).filter(Boolean);

const rubricConfigs = [
  { tag: '#МЛРМ', id: 'mlrm', mark: 'М', name: '#МЛРМ', desc: 'Мой Любимый Реальный Мир. Рынки, власть, информация, геополитика и большие системы.' },
  { tag: '#WAYAWAY', id: 'wayaway', mark: 'W', name: '#WAYAWAY', desc: 'Полевые тексты о местах как инструментах расширения мышления.' },
  { tag: '#красивое', id: 'krasivoe', mark: 'К', name: '#Красивое', desc: 'Проекты, визуал, кино, архитектура и цифровое искусство как способ читать форму.' },
  { tag: '#намолнии', id: 'namolnii', mark: 'Н', name: '#намолнии', desc: 'Короткие удары: одна сцена, одна формула, один нерв без длинного разгона.' },
  { tag: '#душетушка', id: 'dushetushka', mark: 'Д', name: '#Душетушка', desc: 'Тело, дисциплина, желание, ограничения и странная экономика человеческого ресурса.' },
  { tag: '#WIMM', id: 'wimm', mark: '?', name: '#WIMM', desc: 'Where is my mind: сбои восприятия, внутренний шум, культурные странности и сдвиги.' }
];

const rubricCards = rubricConfigs
  .map((rubric) => ({ ...rubric, count: articleList.filter((article) => article.rubrics.includes(rubric.tag)).length }));
---
<!doctype html>
<html lang="ru">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#e5e1d6" />
  <link rel="icon" type="image/png" href="/apple-touch-icon.png" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <meta name="robots" content="index,follow,max-image-preview:large" />
  <title>{siteTitle}</title>
  <meta name="description" content={siteDescription} />
  <meta name="author" content="Nikita Kolbovskiy" />
  <link rel="author" href="https://kolbovskiy.com/" />
  <link rel="me" href="https://kolbovskiy.com/" />
  <link rel="me" href="https://kolbovskiy.pics/" />
  <link rel="me" href="https://t.me/klb_clb" />
  <link rel="canonical" href={siteCanonical} />
  <link rel="alternate" type="application/rss+xml" title="kolbovskiy.club RSS" href={`${siteUrl}/rss.xml`} />
<meta property="og:type" content="website" />
  <meta property="og:locale" content="ru_RU" />
  <meta property="og:site_name" content="kolbovskiy.club" />
  <meta property="og:title" content={siteTitle} />
  <meta property="og:description" content={siteDescription} />
  <meta property="og:url" content={siteCanonical} />
  <meta property="og:image" content={siteOgImage} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={siteTitle} />
  <meta name="twitter:description" content={siteDescription} />
  <meta name="twitter:image" content={siteOgImage} />
  <script type="application/ld+json" set:html={JSON.stringify(webSiteJsonLd)}></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,400;0,500;0,700;1,400;1,500&display=swap');
    @font-face{font-family:DAMN;src:url('/fonts/DAMN.ttf') format('truetype');font-weight:400;font-style:normal;font-display:block;font-synthesis:none}

    :root{
      --red:#d10b0b;
      --white:#F0EDE6;
      --black:#0A0A09;
      --cream:#EBE6D9;
      --soft:#E6E2D6;
      --muted:rgba(10,10,9,.58);
      --faint:rgba(10,10,9,.36);
      --line:rgba(10,10,9,.16);
      --line-strong:rgba(10,10,9,.34);
      --font-display:'DAMN','JetBrains Mono',sans-serif;
      --font-ui:'JetBrains Mono','Cascadia Mono',Consolas,'Courier New',ui-monospace,monospace;
      --pad:clamp(20px,4vw,56px);
      --col:min(680px,calc(100vw - var(--pad)*2));
      --ease:cubic-bezier(.16,1,.3,1);
      --motion-instant:.12s;
      --motion-fast:.18s;
      --motion-ui:.25s;
      --motion-hover:.35s;
      --motion-panel:.52s;
      --motion-sweep:.55s;
      --motion-pulse:1.8s;
      --motion-rail:2.4s;
      --motion-ticker:42s;
      --motion-word:1s;
      --motion-wave-a:24s;
      --motion-wave-b:26s;
    }

    *{box-sizing:border-box;margin:0;padding:0}
    html{background:var(--white);color:var(--black);font-family:var(--font-ui);-webkit-font-smoothing:antialiased;text-rendering:geometricPrecision;font-synthesis:none;text-rendering:optimizeLegibility;scroll-behavior:smooth}
    body{min-height:100vh;background:var(--black);overflow-x:hidden;font-family:var(--font-ui)}
    main{position:relative;z-index:2;background:var(--white)}
    a{color:inherit;text-decoration:none}
    button,input,textarea,select{font-family:var(--font-ui);color:inherit}
    button{font:inherit;color:inherit}
    ::selection{background:var(--red);color:var(--white)}
    .red{color:var(--red)}
    .dim{color:var(--muted)}
    .dot{display:inline-block;width:7px;height:7px;border-radius:50%;background:var(--red);vertical-align:middle;flex:0 0 auto}
    .dot-pulse{animation:pulse var(--motion-pulse) infinite}
    @keyframes pulse{0%,100%{transform:scale(1);opacity:1}50%{transform:scale(1.32);opacity:.55}}

    .arrow-icon{display:inline-block;width:42px;height:12px;background:currentColor;transition:transform var(--motion-hover) var(--ease);-webkit-mask:url('/assets/Arrow.png') center/contain no-repeat;mask:url('/assets/Arrow.png') center/contain no-repeat}

    /* HEADER */
    .site-header{position:sticky;top:0;z-index:100;height:58px;overflow:visible;background:transparent;border-bottom:0;box-shadow:none;transition:none}
    .topbar{position:relative;z-index:3;height:58px;padding:0 var(--pad);display:grid;grid-template-columns:1fr auto 1fr;align-items:center;font-size:11px;line-height:1;letter-spacing:.08em;text-transform:uppercase;background:rgba(240,237,230,.96);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);border-bottom:1px solid var(--line)}
    .top-left,.top-right{display:flex;align-items:center;gap:18px;min-width:0}
    .top-left{justify-self:start;color:var(--muted)}
    .top-right{justify-self:end}
    .status{display:flex;gap:8px;align-items:center;color:var(--red);font-weight:700;white-space:nowrap}
    .top-note{white-space:nowrap;color:var(--muted)}
    .brand-logo{justify-self:center;display:flex;align-items:center;line-height:0}
    .logo-img{display:block;width:min(226px,32vw);height:auto}
    .tg-link{color:var(--black);transition:color var(--motion-ui) var(--ease)}
    .tg-link:hover{color:var(--red)}

    .nav-row{position:absolute;left:0;right:0;top:58px;z-index:8;height:34px;padding:0 var(--pad);display:grid;grid-template-columns:1fr auto 1fr;align-items:center;border-top:1px solid rgba(10,10,9,.08);border-bottom:1px solid var(--line);font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);background:rgba(240,237,230,.94);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);transform:translateY(0);opacity:1;pointer-events:auto;transition:transform var(--motion-panel) var(--ease),opacity var(--motion-hover) var(--ease);will-change:transform,opacity}
    .nav-row-hidden .site-header{height:58px}
    .nav-row-hidden .nav-row{transform:translateY(-100%);opacity:0;pointer-events:none}
    .nav-core{grid-column:2;display:flex;align-items:center;justify-content:center;gap:26px}
    .nav-row a{transition:color var(--motion-ui) var(--ease)}
    .nav-row a:hover{color:var(--red)}
    .search-inline{grid-column:3;justify-self:end;border:0;background:transparent;color:var(--black);cursor:pointer;text-transform:uppercase;font-size:10px;letter-spacing:.14em;border-bottom:1px solid rgba(10,10,9,.28);padding-bottom:2px;transition:color var(--motion-ui) var(--ease),border-color var(--motion-ui) var(--ease)}
    .search-inline:hover{color:var(--red);border-color:var(--red)}

    .mobile-menu-toggle{display:none;width:38px;height:38px;border:0;background:transparent;padding:0;cursor:pointer;align-items:center;justify-content:center}
    .skull{width:26px;height:26px;display:block;background:url('/assets/apple-touch-icon.png') center/contain no-repeat;transition:transform var(--motion-hover) var(--ease),background-image var(--motion-ui) var(--ease)}
    .menu-open .skull{transform:rotate(180deg);background-image:url('/assets/apple-touch-icon_red.png')}
    .menu-open{overflow:hidden}

    .mobile-panel{position:fixed;left:0;right:0;top:58px;z-index:95;background:var(--red);color:var(--white);transform:translateY(-120%);transition:transform var(--motion-panel) var(--ease);border-bottom:1px solid var(--black);padding:32px var(--pad) 38px;max-height:calc(100dvh - 58px);overflow:auto}
    .menu-open .mobile-panel{transform:translateY(0)}
    .mobile-panel-inner{width:100%;margin:0}
    .mobile-panel__head{display:flex;justify-content:space-between;gap:20px;margin-bottom:28px;color:rgba(240,237,230,.78);font-size:10px;line-height:1.35;letter-spacing:.16em;text-transform:uppercase;text-align:left}
    .mobile-panel nav{display:flex;flex-direction:column;gap:13px;align-items:flex-start;text-align:left}
    .mobile-panel a{font-family:var(--font-display);font-size:clamp(34px,10vw,54px);line-height:.88;text-transform:uppercase;color:var(--white);letter-spacing:-.01em}
    .mobile-panel .mobile-small{margin-top:26px;padding-top:18px;border-top:1px solid rgba(240,237,230,.35);display:grid;gap:10px;font-family:var(--font-ui);font-size:11px;text-transform:uppercase;letter-spacing:.12em;color:rgba(240,237,230,.82)}
    .mobile-panel .mobile-small a{font-family:var(--font-ui);font-size:11px;line-height:1.3;letter-spacing:.12em}

    /* SEARCH */
    .search-panel{position:fixed;inset:0;z-index:120;background:rgba(10,10,9,.90);backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);color:var(--white);display:none;padding:clamp(28px,6vw,72px)}
    .search-open .search-panel{display:block}
    .search-box{width:min(1180px,calc(100vw - var(--pad)*2));max-width:1180px;margin:0 auto;display:grid;gap:26px}
    .search-head{display:flex;justify-content:space-between;gap:20px;align-items:center;color:rgba(240,237,230,.62);font-size:11px;letter-spacing:.16em;text-transform:uppercase}
    .search-close{width:42px;height:42px;border:0;background:transparent;color:var(--white);padding:0;cursor:pointer;display:flex;align-items:center;justify-content:center}
    .search-close-icon{display:block;width:26px;height:26px;background:rgba(240,237,230,.86);-webkit-mask:url('/assets/Cross_45.png') center/contain no-repeat;mask:url('/assets/Cross_45.png') center/contain no-repeat;transition:transform var(--motion-hover) var(--ease),background var(--motion-ui) var(--ease)}
    .search-close:hover .search-close-icon{background:var(--red);transform:rotate(90deg) scale(1.08)}
    .search-input{width:100%;border:0;border-bottom:1px solid rgba(240,237,230,.42);background:transparent;color:var(--white);font-size:clamp(28px,6vw,72px);line-height:1.05;padding:12px 34px 18px 0;outline:0;text-transform:uppercase;letter-spacing:-.03em;-webkit-appearance:none;appearance:none}
    .search-input::placeholder{color:transparent}
    .search-input::-webkit-search-decoration{display:none}
    .search-input::-webkit-search-cancel-button{-webkit-appearance:none!important;appearance:none!important;width:18px;height:18px;background:rgba(240,237,230,.72)!important;-webkit-mask:url('/assets/Cross_45.png') center/contain no-repeat;mask:url('/assets/Cross_45.png') center/contain no-repeat;cursor:pointer;transition:background var(--motion-ui) var(--ease),transform var(--motion-hover) var(--ease)}
    .search-input::-webkit-search-cancel-button:hover{background:var(--red)!important;transform:rotate(90deg)}
    .search-input::-ms-clear{display:none;width:0;height:0}
    .search-input::-ms-reveal{display:none;width:0;height:0}
    .search-input::-webkit-contacts-auto-fill-button,
    .search-input::-webkit-credentials-auto-fill-button{visibility:hidden;display:none!important;pointer-events:none;position:absolute;right:0}
    .search-results{display:grid;border-top:1px solid rgba(240,237,230,.25)}
    .search-result{display:grid;grid-template-columns:80px 120px 1fr 28px;gap:18px;align-items:center;padding:18px 0;border-bottom:1px solid rgba(240,237,230,.18);font-size:12px;letter-spacing:.08em;text-transform:uppercase;color:rgba(240,237,230,.68)}
    .search-result b{color:var(--white);font-weight:500;text-transform:none;letter-spacing:0;font-size:14px}
    .search-result .rub{color:var(--red)}
    .search-result .go{display:flex;justify-content:flex-end;align-items:center;color:var(--red)}
    .search-triangle{display:block;width:16px;height:16px;background:var(--red);clip-path:polygon(0 0,100% 50%,0 100%);transition:transform var(--motion-hover) var(--ease),opacity var(--motion-ui) var(--ease);opacity:.86}
    .search-result:hover .search-triangle{transform:translateX(7px);opacity:1}
    .search-empty{padding:18px 0;border-bottom:1px solid rgba(240,237,230,.18);color:rgba(240,237,230,.55);font-size:12px;letter-spacing:.12em;text-transform:uppercase}

    /* HERO */
    .hero{position:relative;min-height:calc(100vh - 92px);overflow:hidden;background:#1b120e;color:var(--white);border-bottom:1px solid var(--black)}
    .hero-bg{position:absolute;inset:0;background:url('/assets/test.jpg') center center/cover no-repeat;transform:none;filter:none}
    .hero:before{content:"";position:absolute;inset:0;z-index:1;background:linear-gradient(90deg,rgba(10,10,9,.72) 0%,rgba(10,10,9,.38) 42%,rgba(10,10,9,.78) 100%),linear-gradient(180deg,rgba(10,10,9,.42) 0%,rgba(10,10,9,.18) 40%,rgba(10,10,9,.74) 100%)}
    .hero:after{content:"";position:absolute;inset:0;z-index:2;pointer-events:none;opacity:.10;mix-blend-mode:screen;background:repeating-linear-gradient(0deg,rgba(240,237,230,.09) 0 1px,transparent 1px 96px),repeating-linear-gradient(90deg,rgba(240,237,230,.07) 0 1px,transparent 1px 96px)}
    .hero-inner{position:relative;z-index:3;min-height:calc(100vh - 92px);padding:44px var(--pad) 48px;display:grid;grid-template-rows:auto 1fr auto;gap:18px}
    .hero-meta{display:grid;grid-template-columns:1fr auto;align-items:center;gap:18px;color:rgba(240,237,230,.70);font-size:11px;letter-spacing:.10em;text-transform:uppercase}
    .hero-meta .right{text-align:right}
    .hero-main{align-self:center;width:100%;max-width:none;position:relative;padding-top:0;transform:translateY(72px)}
    .hero-eyebrow{position:absolute;left:0;top:-76px;z-index:8;display:grid;grid-template-columns:12px max-content;align-items:center;column-gap:10px;width:max-content;max-width:100%;height:14px;padding:0;margin:0;background:transparent!important;border:0!important;box-shadow:none!important;color:var(--red);font-size:11px;line-height:14px;letter-spacing:.10em;text-transform:uppercase;white-space:nowrap;pointer-events:none}
    .hero-eyebrow .rubric-text{display:block;color:var(--red);font-weight:700;background:transparent!important;border:0!important;padding:0!important;margin:0!important;line-height:14px;white-space:nowrap}
    .rubric-pulse{display:block;width:12px;height:12px;border-radius:50%;background:var(--red);animation:dotPulse var(--motion-pulse) infinite;transform:none!important}
    @keyframes dotPulse{0%,100%{opacity:1}50%{opacity:.42}}
    .hero-title-row{position:relative;width:100%;max-width:none;display:grid;grid-template-columns:minmax(0,max-content) 1fr;align-items:start;column-gap:clamp(28px,7vw,110px);font-size:clamp(112px,15.5vw,248px);line-height:.78}
    .hero-title{font-family:var(--font-display);font-weight:400;color:var(--red);font-size:1em;line-height:.78;letter-spacing:-.018em;text-transform:uppercase;text-shadow:none;-webkit-text-stroke:0;paint-order:normal;height:auto;overflow:visible;justify-self:start}
    .hero-title-rail{position:relative;display:block;width:1px;height:.68em;margin-top:-.045em;background:rgba(240,237,230,.34);overflow:hidden;justify-self:end;align-self:start}
    .hero-title-rail span{position:absolute;left:0;top:-38%;display:block;width:1px;height:38%;background:var(--red);animation:titleRailRun var(--motion-rail) ease-in-out infinite}
    @keyframes titleRailRun{0%{transform:translateY(0)}55%,100%{transform:translateY(365%)}}
    .hero-title span{display:inline-block;animation:none!important;transform:none!important;-webkit-font-smoothing:antialiased}
    .hero-title-gap{display:inline!important;width:.08em}
    .hero-sub{max-width:700px;margin-top:18px;color:var(--white);font-size:clamp(17px,1.75vw,24px);font-style:italic;line-height:1.36;text-shadow:0 1px 18px rgba(0,0,0,.34)}
    .hero-lede{max-width:590px;margin-top:14px;color:rgba(240,237,230,.72);font-size:14px;line-height:1.56;font-style:italic;text-shadow:0 1px 16px rgba(0,0,0,.30)}
    .read-link{display:inline-flex;align-items:center;gap:14px;margin-top:22px;color:var(--white);font-weight:700;font-size:13px;letter-spacing:.08em;text-transform:uppercase}
    .read-link .arrow-icon{color:var(--red)}.read-link:hover .arrow-icon{transform:translateX(10px)}
    .hero-foot{display:flex;justify-content:space-between;align-items:flex-end;gap:24px;color:rgba(240,237,230,.54);font-size:10px;line-height:1.35;letter-spacing:.10em;text-transform:uppercase;padding-right:44px}
    .hero-filemeta{display:flex;flex-wrap:wrap;gap:8px 18px}
    .hero-filemeta span{display:inline-flex;gap:7px;align-items:center}
    .hero-filemeta b{color:rgba(240,237,230,.82);font-weight:700}
    .hero-scroll-rail{display:none}

    .ticker{border-top:1px solid var(--white);border-bottom:1px solid var(--white);background:var(--black);color:var(--white);overflow:hidden;white-space:nowrap;display:flex;padding:14px 0}
    .ticker-track{display:inline-flex;gap:56px;padding-left:56px;animation:tick var(--motion-ticker) linear infinite;font-weight:500;font-size:14px;letter-spacing:.12em;text-transform:uppercase;flex-shrink:0}
    .ticker-track .sep{color:var(--red)}
    @keyframes tick{from{transform:translateX(0)}to{transform:translateX(-50%)}}

    /* SECTIONS */
    .section{padding:88px var(--pad);border-bottom:1px solid var(--line)}
    .section-inner{max-width:1180px;margin:0 auto}
    .section-head{display:grid;grid-template-columns:1fr auto;align-items:end;gap:24px;margin-bottom:30px}
    .section-title{font-family:var(--font-display);font-weight:400;font-size:clamp(48px,6.6vw,104px);line-height:.86;letter-spacing:-.012em;text-transform:uppercase;color:var(--black);text-shadow:none;-webkit-text-stroke:0}
    .section-kicker{display:block;margin-bottom:10px;color:var(--red);font-family:var(--font-ui);font-size:11px;line-height:1;letter-spacing:.18em;text-transform:uppercase}
    .section-meta{display:flex;flex-direction:column;gap:8px;text-align:right;font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted)}
    .section-meta .big{font-family:var(--font-display);font-size:52px;color:var(--black);line-height:.9;letter-spacing:0;font-weight:400;text-shadow:none;-webkit-text-stroke:0}
    .section-intro{max-width:var(--col);margin:0 0 48px;color:var(--black);font-size:clamp(16px,1.15vw,18px);line-height:1.58;font-style:normal}
    .text-col{max-width:var(--col)}

    /* FRESH */
    .fresh-grid{display:grid;grid-template-columns:repeat(3,1fr);border-top:1px solid var(--black);border-left:1px solid var(--line)}
    .fresh-card{position:relative;min-height:320px;padding:26px 24px;border-right:1px solid var(--line);border-bottom:1px solid var(--line);display:flex;flex-direction:column;gap:18px;overflow:hidden;background:rgba(240,237,230,.24);transition:background var(--motion-ui) var(--ease),transform var(--motion-hover) var(--ease)}
    .fresh-card.has-image{background-image:var(--fresh-image);background-size:100% auto;background-position:center var(--fresh-y,center);background-repeat:no-repeat}
    .fresh-card:before{content:"";position:absolute;inset:0;z-index:0;opacity:.48;background:repeating-linear-gradient(0deg,rgba(10,10,9,.06) 0 1px,transparent 1px 28px),repeating-linear-gradient(90deg,rgba(10,10,9,.06) 0 1px,transparent 1px 28px)}
    .fresh-card:after{content:"";position:absolute;right:18px;top:18px;width:7px;height:7px;border-radius:50%;background:var(--red);z-index:1}
    .fresh-card:hover{transform:translateY(-3px)}
    .fresh-card>*{position:relative;z-index:1}
    .fresh-card .no{color:var(--red);font-size:12px;letter-spacing:.12em;text-transform:uppercase;font-weight:700}
    .fresh-card h3{font-family:var(--font-display);font-weight:400;font-size:clamp(38px,4vw,64px);line-height:.88;letter-spacing:-.012em;text-transform:uppercase;color:var(--black);-webkit-text-stroke:0;text-shadow:none}
    .fresh-card p{margin-top:auto;color:var(--muted);font-size:13px;line-height:1.55;font-style:italic;max-width:92%}
    .fresh-card .go{display:flex;align-items:center;gap:12px;color:var(--red);font-size:11px;text-transform:uppercase;letter-spacing:.12em;font-weight:700}
    .fresh-card:hover .arrow-icon{transform:translateX(8px)}

    /* BEST */
    .start{background:var(--cream)}
    .best-layout{display:grid;grid-template-columns:minmax(320px,var(--col)) minmax(420px,1fr);gap:clamp(42px,7vw,86px);align-items:start}
    .best-copy{max-width:var(--col)}
    .best-label{display:block;margin-bottom:18px;color:var(--muted);font-size:13px;line-height:1.5;font-style:italic}
    .best-issue-title{font-family:var(--font-display);font-weight:400;font-style:normal;color:var(--black);font-size:clamp(42px,5.2vw,86px);line-height:.86;letter-spacing:-.014em;text-transform:uppercase;margin-bottom:22px;-webkit-text-stroke:0;text-shadow:none}
    .best-copy p{color:var(--muted);font-size:14px;line-height:1.58;font-style:italic;margin-bottom:24px}

    .best-main-cover{position:relative;display:block;width:100%;aspect-ratio:1/1;height:auto;margin:0 0 18px;border:1px solid var(--line-strong);background:rgba(240,237,230,.26);overflow:hidden}
    .best-cover-image{position:absolute;inset:0;z-index:0;width:100%;height:100%;object-fit:cover;display:block}
    .best-main-cover:before{content:"";position:absolute;inset:0;z-index:1;opacity:.58;background:repeating-linear-gradient(0deg,rgba(10,10,9,.07) 0 1px,transparent 1px 18px),repeating-linear-gradient(90deg,rgba(10,10,9,.07) 0 1px,transparent 1px 18px)}
    .best-main-cover:after{content:"";position:absolute;right:18px;top:18px;width:9px;height:9px;border-radius:50%;background:var(--red);z-index:2}
    .best-main-cover .cover-no{position:absolute;left:24px;top:24px;z-index:2;color:var(--red);font-size:12px;letter-spacing:.12em;text-transform:uppercase;font-weight:700}
    .best-main-cover .cover-title{position:absolute;left:24px;right:24px;bottom:74px;z-index:2;font-family:var(--font-display);font-weight:400;font-style:normal;color:var(--white);font-size:clamp(64px,7.4vw,116px);line-height:.78;letter-spacing:-.012em;text-transform:uppercase;-webkit-text-stroke:0;text-shadow:none}
    .best-main-cover .cover-meta{position:absolute;left:24px;right:24px;bottom:24px;z-index:2;color:var(--muted);font-size:11px;letter-spacing:.12em;text-transform:uppercase}
    .best-album-note{max-width:var(--col);margin:0 0 20px;color:var(--black);font-size:clamp(16px,1.15vw,18px);line-height:1.55;font-style:normal}
    .best-list{display:grid;border-top:1px solid var(--black)}
    .best-list a{display:grid;grid-template-columns:42px 1fr auto;gap:16px;align-items:center;padding:16px 0;border-bottom:1px solid var(--line);transition:padding-left var(--motion-hover) var(--ease)}
    .best-list a:hover{padding-left:10px}
    .best-list .num{color:var(--red);font-size:12px;letter-spacing:.10em;font-weight:700}
    .best-list .ttl{font-size:14px;line-height:1.35;font-weight:700;font-style:italic;color:var(--black)}
    .best-list .go{color:var(--red)}
    .issue-covers{display:flex;flex-direction:column;border-top:1px solid var(--black)}
    .issue-cover{position:relative;display:grid;grid-template-columns:112px 1fr auto;gap:22px;align-items:center;padding:18px 0;border-bottom:1px solid var(--line);background:transparent;overflow:visible;transition:padding-left var(--motion-hover) var(--ease)}
    .issue-cover:hover{padding-left:18px}
    .issue-cover-thumb{position:relative;width:112px;height:112px;border:1px solid var(--line-strong);background:rgba(240,237,230,.26);overflow:hidden;flex:0 0 auto}
    .issue-cover-image{position:absolute;inset:0;z-index:0;width:100%;height:100%;object-fit:cover;display:block}
    .issue-cover-thumb:before{content:"";position:absolute;inset:0;z-index:1;opacity:.58;background:repeating-linear-gradient(0deg,rgba(10,10,9,.07) 0 1px,transparent 1px 18px),repeating-linear-gradient(90deg,rgba(10,10,9,.07) 0 1px,transparent 1px 18px)}
    .issue-cover-thumb:after{content:"";position:absolute;right:9px;top:9px;z-index:2;width:7px;height:7px;border-radius:50%;background:var(--red)}
    .issue-cover-thumb .mini-title{position:absolute;left:11px;bottom:10px;right:10px;z-index:2;font-family:var(--font-display);font-size:34px;line-height:.78;text-transform:uppercase;color:var(--black);letter-spacing:-.01em}
    .issue-cover-body{min-width:0}
    .issue-cover .issue-no{display:block;margin-bottom:8px;color:var(--red);font-size:11px;letter-spacing:.12em;text-transform:uppercase;font-weight:700}
    .issue-cover-title{display:block;font-family:var(--font-display);font-weight:400;font-style:normal;color:var(--black);font-size:clamp(32px,3.2vw,52px);line-height:.86;letter-spacing:-.012em;text-transform:uppercase;-webkit-text-stroke:0;text-shadow:none}
    .issue-cover p{margin-top:8px;color:var(--muted);font-size:12px;line-height:1.45;font-style:italic;max-width:92%}
    .issue-cover .issue-foot{margin-top:10px;display:flex;gap:18px;align-items:center;color:var(--muted);font-size:10px;letter-spacing:.10em;text-transform:uppercase}
    .issue-cover .open{color:var(--red);font-weight:700}
    .issue-cover-go{color:var(--red)}
    .issue-cover:hover .issue-cover-go .arrow-icon{transform:translateX(8px)}

    /* ARCHIVE */
    .archive-head,.row{display:grid;grid-template-columns:80px 110px 130px 1fr 80px 40px;gap:16px;align-items:center}
    .archive-head{padding:14px 0;border-top:1px solid var(--black);border-bottom:1px solid var(--line);font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:var(--muted)}
    .archive-head span:nth-child(5),.archive-head span:nth-child(6){text-align:right}
    .row{position:relative;overflow:hidden;padding:18px 0;border-bottom:1px solid var(--line);font-size:14px}
    .row:before{content:"";position:absolute;left:-100%;top:0;bottom:0;width:100%;background:linear-gradient(90deg,transparent 0%,rgba(209,11,11,.10) 25%,rgba(209,11,11,.20) 100%);transition:left var(--motion-sweep) var(--ease);pointer-events:none}
    .row:hover:before{left:0}
    .row>*{position:relative;z-index:1}
    .row .no,.row .date,.row .rub,.row .min{color:var(--muted);font-size:11px;letter-spacing:.08em;text-transform:uppercase}
    .row .rub{color:var(--red)}
    .row .ttl{font-weight:500;font-size:15px;line-height:1.35;transition:transform var(--motion-hover) var(--ease)}
    .row .ttl em{color:var(--muted);font-style:italic;font-weight:400}
    .row:hover .ttl{transform:translateX(8px)}
    .row .min{text-align:right}.row .go{color:var(--red);text-align:right}
    .row:hover .go .arrow-icon{transform:translateX(8px)}
    .archive-foot{display:flex;justify-content:space-between;align-items:center;margin-top:28px;color:var(--muted);font-size:11px;letter-spacing:.08em;text-transform:uppercase}
    .archive-foot a{display:inline-flex;align-items:center;gap:10px;color:var(--red);font-weight:700}
    .arrow-down{transform:rotate(90deg);transform-origin:center center}
    .archive-foot a:hover .arrow-down{transform:rotate(90deg) translateX(8px)}

    /* RUBRICS */
    .rubrics-wrap{padding-bottom:clamp(36px,4vw,56px)}
    .rubrics{display:grid;grid-template-columns:repeat(6,minmax(0,1fr));max-width:1180px;margin:0 auto;border-top:1px solid var(--black);border-left:1px solid var(--line);border-right:1px solid var(--line);border-bottom:1px solid var(--line);background:var(--white)}
    .rubric{min-height:288px;padding:24px 20px 20px;border-right:1px solid var(--line);border-bottom:1px solid var(--line);margin-bottom:-1px;display:flex;flex-direction:column;transition:background var(--motion-ui) var(--ease)}
    .rubric:nth-child(6n){border-right:0}
    .rubric:hover{background:#E6E2D6}
    .rubric-mark{font-family:var(--font-display);color:var(--red);font-size:clamp(62px,6.8vw,108px);line-height:.76;margin-bottom:18px;transition:none;font-weight:400;text-shadow:none;-webkit-text-stroke:0;}
    .rubric:hover .rubric-mark{transform:none}
    .rubric-name{font-weight:700;font-size:12px;letter-spacing:.08em;text-transform:uppercase;margin-bottom:12px}
    .rubric-desc{color:var(--muted);font-style:italic;font-size:12px;line-height:1.5;min-height:88px}
    .rubric-meta{margin-top:auto;display:flex;justify-content:space-between;align-items:baseline;color:var(--muted);font-size:10px;letter-spacing:.08em;text-transform:uppercase}
    .rubric-meta .count{font-family:var(--font-display);font-weight:400;font-size:24px;color:var(--black);letter-spacing:0;text-shadow:none;-webkit-text-stroke:0}

    /* FOOTER */
    .foot{position:sticky;bottom:0;z-index:0;background:var(--black);color:var(--white);min-height:0;padding:clamp(46px,6.4vh,74px) var(--pad) 0;overflow:hidden}
    .foot-inner{width:100%;max-width:none;margin:0 auto}
    .foot-title{font-family:var(--font-display);font-weight:400;color:var(--white);font-size:clamp(44px,6.2vw,104px);line-height:.84;letter-spacing:-.014em;text-transform:none;text-shadow:none;-webkit-text-stroke:0;margin:0 0 18px;max-width:none}
    .foot-cta{display:inline-flex;align-items:center;gap:14px;color:var(--red);font-weight:700;font-size:13px;letter-spacing:.08em;text-transform:uppercase;margin:0 0 clamp(30px,4vh,44px)}
    .foot-cta:hover .arrow-icon{transform:translateX(10px)}
    .foot-meta{display:grid;grid-template-columns:minmax(0,1fr) auto;gap:32px;align-items:end;width:100%;padding:0 0 24px}
    .foot-credits{display:grid;gap:9px;color:rgba(240,237,230,.54);font-size:11px;line-height:1.55;letter-spacing:.08em;text-transform:uppercase;font-weight:500}
    .foot-credits a{color:rgba(240,237,230,.78);text-decoration:none;border-bottom:1px solid rgba(240,237,230,.28);transition:color var(--motion-ui) var(--ease),border-color var(--motion-ui) var(--ease)}
    .foot-credits a:hover{color:var(--red);border-color:var(--red)}
    .age-mark{justify-self:end;align-self:end;color:var(--white);font-weight:700;font-size:clamp(16px,1.4vw,22px);line-height:1;letter-spacing:.04em;text-transform:uppercase}
    .foot-bottom{display:grid;grid-template-columns:1fr auto;gap:24px;align-items:center;width:100%;height:58px;border-top:1px solid rgba(240,237,230,.18);font-size:11px;letter-spacing:.08em;text-transform:uppercase;font-weight:500;color:rgba(240,237,230,.54)}
    .foot-bottom-links{display:none}
    .foot-bottom a{color:rgba(240,237,230,.72);text-decoration:none;transition:color var(--motion-ui) var(--ease)}
    .foot-bottom a:hover{color:var(--red)}

    @media(max-width:1100px){
      .nav-core{gap:16px}.top-note{display:none}.fresh{grid-template-columns:1fr}.fresh-pitch{max-width:var(--col)}.start-grid{grid-template-columns:1fr 1fr}.rubrics{grid-template-columns:1fr 1fr}.rubric{min-height:260px}.rubric:nth-child(6n){border-right:1px solid var(--line)}.rubric:nth-child(2n){border-right:0}.foot-meta{grid-template-columns:1fr auto}
    }
    @media(max-width:760px){
      :root{--pad:20px;--col:min(680px,calc(100vw - 40px))}
      .topbar{grid-template-columns:auto 1fr auto;height:56px;padding:0 var(--pad)}.site-header,.nav-row-hidden .site-header{height:56px}.brand-logo{justify-self:start}.logo-img{width:min(184px,50vw)}.top-left{display:none}.top-right{justify-self:end;gap:0}.skull{width:26px;height:26px}.tg-link,.search-inline{display:none}.mobile-menu-toggle{display:flex;justify-content:flex-end}.nav-row{display:none}.mobile-panel{top:56px;max-height:calc(100dvh - 56px)}.mobile-panel-inner{width:100%;margin:0}.search-panel{padding:28px var(--pad)}.search-box{width:100%;max-width:none;margin:0}.search-result{grid-template-columns:52px 1fr 24px}.search-result .rub{display:none}
      .hero,.hero-inner{min-height:calc(100vh - 56px)}.hero-inner{padding:32px var(--pad) 42px}.hero-meta{grid-template-columns:1fr auto;gap:8px}.hero-meta .right{text-align:right}.hero-main{width:100%;max-width:none;padding-top:0;transform:translateY(42px)}.hero-eyebrow{top:-54px;grid-template-columns:10px max-content;column-gap:8px;height:12px;font-size:10px;line-height:12px}.rubric-pulse{width:10px;height:10px}.hero-eyebrow .rubric-text{font-size:10px;line-height:12px}.hero-title-row{width:100%;height:auto;column-gap:16px;font-size:clamp(118px,38vw,220px)}.hero-title{font-size:1em;height:auto}.hero-title-rail{height:.68em;margin-top:-.045em}.hero-sub{font-size:18px;max-width:95%}.hero-lede{font-size:13px;max-width:95%}.hero-foot{font-size:9px;padding-right:28px}.hero-filemeta{display:grid;gap:5px}.hero-scroll-rail{display:none}
      .ticker{padding:11px 0}.ticker-track{font-size:11px;gap:32px;padding-left:32px}.section{padding:56px var(--pad)}.section-head{grid-template-columns:minmax(0,1fr) auto;align-items:end;gap:18px;margin-bottom:24px}.section-title{font-size:clamp(46px,13vw,72px);min-width:0}.section-intro{margin-bottom:32px}.section-meta{text-align:right;flex-direction:column;gap:5px;align-items:flex-end;justify-self:end;min-width:max-content}.section-meta .big{font-size:38px}.fresh-item{grid-template-columns:64px 1fr auto;gap:16px;padding:18px 0}.fresh-item:hover{padding-left:0}.fresh-thumb{width:64px;height:64px}.fresh-meta{gap:10px;flex-wrap:wrap;font-size:10px}.start-grid{grid-template-columns:1fr}.start-card{min-height:220px}.archive-head,.row{grid-template-columns:48px 1fr 28px;gap:14px;padding:14px 0}.archive-head .colDate,.row .date,.archive-head .colMin,.row .min,.archive-head .colRub,.row .rub{display:none}.row .ttl{font-size:14px}.row .ttl em{display:none}.archive-foot{align-items:flex-start;gap:14px;flex-direction:column}.rubrics{grid-template-columns:1fr}.rubric,.rubric:nth-child(2n),.rubric:nth-child(6n){min-height:0;padding:24px 20px 20px;border-right:0;border-bottom:1px solid var(--line)}.rubric-mark{font-size:64px;margin-bottom:12px}.rubric-desc{max-width:none;min-height:0}.rubric-meta{margin-top:18px}.foot{min-height:0;padding:44px var(--pad) 0}.foot-title{font-size:clamp(48px,15vw,86px);max-width:none;margin-bottom:18px}.foot-cta{margin-bottom:30px}.foot-meta{grid-template-columns:1fr auto;gap:22px;padding-bottom:22px}.foot-credits{font-size:10px}.age-mark{font-size:18px}.foot-bottom{grid-template-columns:1fr auto;gap:24px;height:56px}.foot-bottom-links{display:none}
    }

    @media(max-width:1100px){
      .fresh-grid{grid-template-columns:1fr 1fr}.best-layout{grid-template-columns:1fr}.issue-covers{display:flex;flex-direction:column}
    }
    @media(max-width:760px){
      .fresh-grid{grid-template-columns:1fr}.fresh-card{min-height:220px;padding:24px 20px}.fresh-card h3{font-size:clamp(38px,12vw,62px)}.best-layout{grid-template-columns:1fr;gap:32px}.best-issue-title{font-size:clamp(42px,13vw,68px)}.best-main-cover{height:auto;aspect-ratio:1/1;margin:22px 0 18px}.best-main-cover .cover-no{left:18px;top:18px}.best-main-cover .cover-title{left:18px;right:18px;bottom:58px;font-size:clamp(52px,18vw,88px)}.best-main-cover .cover-meta{left:18px;right:18px;bottom:18px}.best-list a{grid-template-columns:34px 1fr auto}.issue-covers{display:flex;flex-direction:column}.issue-cover{grid-template-columns:76px 1fr auto;gap:14px;padding:14px 0}.issue-cover:hover{padding-left:0}.issue-cover-thumb{width:76px;height:76px}.issue-cover-thumb .mini-title{font-size:28px}.issue-cover-title{font-size:clamp(30px,10vw,48px)}.issue-cover p{display:none}
