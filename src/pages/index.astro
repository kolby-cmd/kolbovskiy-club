  <div class="progress" aria-hidden="true"><div class="progress-fill" id="progressFill"></div></div>

  <header class="site-header">
    <div class="topbar">
      <div class="top-left"><span class="top-note">ЧАСТНОЕ МЕДИА / ПУБЛИЧНЫЙ АРХИВ</span></div>
      <a class="brand-logo" href="#top" aria-label="KOLBOVSKIY.CLUB"><img class="logo-img" src="/assets/Logo_damn_1.svg" alt="KOLBOVSKIY.CLUB" /></a>
      <div class="top-right"><a class="tg-link" href="https://t.me/klb_clb" target="_blank" rel="noopener">@klb_clb</a><button class="mobile-menu-toggle" id="menuToggle" type="button" aria-label="Открыть меню"><span class="skull"></span></button></div>
    </div>
    <nav class="nav-row" aria-label="Главное меню"><div class="nav-core"><a href="#fresh">Свежее</a><a href="/best/">Колба</a><a href="/archive/">Бездна</a><a href="/rubrics/">Рубрики</a><a href="/about/">О проекте</a><a href="/privacy-policy/">Дисклеймер</a></div><button class="search-inline" id="searchOpen" type="button">Поиск</button></nav>
  </header>

  <div class="mobile-panel" id="mobilePanel"><div class="mobile-panel-inner"><div class="mobile-panel__head"><span>KOLBOVSKIY.CLUB</span><span>МЕНЮ / УКАЗАТЕЛЬ</span></div><nav><a href="#fresh">Свежее</a><a href="/best/">Колба</a><a href="/archive/">Бездна</a><a href="/rubrics/">Рубрики</a><a href="/about/">О проекте</a><a href="/privacy-policy/">Дисклеймер</a></nav><div class="mobile-small"><a href="#search" id="mobileSearchOpen">Поиск по публикациям →</a><a href="https://t.me/klb_clb" target="_blank" rel="noopener">Канал → @klb_clb</a></div></div></div>

  <aside class="search-panel" id="searchPanel" aria-label="Поиск по публикациям">
    <div class="search-box">
      <div class="search-head"><span>Поиск по публикациям</span><button class="search-close" id="searchClose" type="button" aria-label="Закрыть поиск"><span class="search-close-icon" aria-hidden="true"></span></button></div>
      <input class="search-input" id="searchInput" type="search" placeholder="" aria-label="Поиск по публикациям" />
      <div class="search-results" id="searchResults">
        {searchSuggestions.map((item) => (
          <a class="search-result" href={item.href}>
            <span>{item.issue}</span>
            <span class="rub">{item.rubric}</span>
            <b>{item.label}</b>
            <span class="go"><span class="search-triangle" aria-hidden="true"></span></span>
          </a>
        ))}
      </div>
      <script type="application/json" id="searchIndex" is:inline set:html={JSON.stringify(searchIndex)}></script>
    </div>
  </aside>

  <main id="top">
    <section class="hero" aria-label="Главный материал">
      <div class="hero-bg" style={`--hero-y:${imageFocusY(featuredArticle)}`}>
        <img src={featuredArticle.heroImage ?? '/assets/test.jpg'} alt="" loading="eager" decoding="async" />
      </div>
      <div class="hero-shade" style={heroToneVars(featuredArticle)} aria-hidden="true"></div>
      <div class="hero-inner">
        <div class="hero-meta"><div><span>Главное</span></div><div class="right"><span>{featuredArticle.issue} · {featuredArticle.readTime}</span></div></div>
        <div class="hero-main">
          <div class="hero-eyebrow"><span class="rubric-pulse" aria-hidden="true"></span><span class="rubric-text">{formatRubrics(featuredArticle)}</span></div>
          <div class="hero-title-row"><h1 class="hero-title" aria-label={featuredArticle.title}><span>{heroTitle}</span></h1><div class="hero-title-rail" aria-hidden="true"><span></span></div></div>
          <p class="hero-sub" set:html={heroCaptionHtml}></p>
          <a class="read-link" href={articleHref(featuredArticle)}>Читать <span class="arrow-icon" aria-hidden="true"></span></a>
        </div>
        <div class="hero-foot"><div class="hero-filemeta"><span><b>Тезис:</b> {featuredArticle.thesis}</span><span><b>Оптика:</b> {topicsLine(featuredArticle)}</span></div></div>
      </div>
    </section>

    <div class="ticker" aria-hidden="true"><div class="ticker-track"><span>Частное медиа о Реальном мире</span><span class="sep">●</span><span>сигнал сильнее шума</span><span class="sep">●</span><span>{archiveTotal} проиндексированных материалов</span><span class="sep">●</span><span>архив / эссе / полевые заметки</span><span class="sep">●</span><span>In incerto we trust</span><span class="sep">●</span><span>Частное медиа о Реальном мире</span><span class="sep">●</span><span>сигнал сильнее шума</span><span class="sep">●</span><span>{archiveTotal} проиндексированных материалов</span><span class="sep">●</span><span>архив / эссе / полевые заметки</span><span class="sep">●</span><span>In incerto we trust</span><span class="sep">●</span></div></div>

    <section class="section" id="fresh">
      <div class="section-inner">
        <div class="section-head"><h2 class="section-title"><span class="section-kicker">01 / сигналы</span>Свежее</h2><div class="section-meta"><span>последние материалы</span><span class="big">{String(freshArticles.length).padStart(2, '0')}</span></div></div>
        <p class="section-intro">Верхний слой: последние материалы, разложенные по архиву и связанные с соседними линиями.</p>
        <div class="fresh-grid">
          {freshArticles.map((item) => (
            <a
              class="fresh-card has-image"
              href={articleHref(item)}
            >
              <span class="fresh-media">
                <img class="fresh-media-image" src={String(item.heroImage)} alt="" loading="lazy" decoding="async" style={`object-position:center ${imageFocusY(item)}`} />
              </span>
              <span class="fresh-body">
                <span class="no">{item.issue} / {formatRubric(item.rubrics[0])}</span>
                <h3>{item.title}</h3>
                <p>{item.description}</p>
                <span class="go">читать <span class="arrow-icon" aria-hidden="true"></span></span>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

<section class="section start" id="best">
      <div class="section-inner">
        <div class="section-head"><h2 class="section-title"><span class="section-kicker">02 / greatest hi[ea]ts</span>Колба</h2><div class="section-meta"><span>выпуски</span><span class="big">{String(kolbaVolumes.length).padStart(2, '0')}</span></div></div>
        <p class="section-intro">Сборники сильных текстов: подшивки материалов, которые лучше работают рядом, чем по одному в потоке.</p>
        <div class="best-layout">
          <div class="best-copy">
            <a class="best-main-cover" href={`/best/#${kolbaVolumes[0].id}`}>
              <img class="best-cover-image" src={kolbaVolumes[0].coverImage} alt="" loading="lazy" decoding="async" />
              <span class="cover-no">выпуск №{kolbaVolumes[0].no}</span><span class="cover-title">{kolbaVolumes[0].title}</span><span class="cover-meta">{kolbaVolumes[0].count} / последний выпуск</span>
            </a>
            <p class="best-album-note">{kolbaVolumes[0].desc}</p>
            <div class="best-list">
              {kolbaLeadArticles.map((item, index) => (
                <a href={articleHref(item)}><span class="num">{String(index + 1).padStart(2, '0')}</span><span class="ttl">{item.title}</span><span class="go"><span class="arrow-icon" aria-hidden="true"></span></span></a>
              ))}
            </div>
          </div>
          <div class="issue-covers">
            {kolbaVolumes.slice(1).map((volume) => (
              <a class="issue-cover" href={`/best/#${volume.id}`}><span class="issue-cover-thumb"><img class="issue-cover-image" src={volume.coverImage} alt="" loading="lazy" decoding="async" /></span><span class="issue-cover-body"><span class="issue-no">выпуск №{volume.no}</span><strong class="issue-cover-title">{volume.title}</strong><p>{volume.desc}</p><span class="issue-foot"><span>{volume.count}</span></span></span><span class="issue-cover-go"><span class="arrow-icon" aria-hidden="true"></span></span></a>
            ))}
          </div>
        </div>
      </div>
    </section>

<section class="section" id="archive">
      <div class="section-inner">
        <div class="section-head"><h2 class="section-title"><span class="section-kicker">03 / хронология</span>Архив</h2><div class="section-meta"><span>материалы</span><span class="big">{archiveTotal}</span></div></div>
        <div class="archive-head"><span>№</span><span class="colDate">Дата</span><span class="colRub">Рубрика</span><span>Заголовок</span><span class="colMin">Чтение</span><span></span></div>
        <div class="archive">
          {archivePreview.map((item) => (
            <a class="row" href={articleHref(item)}>
              <span class="no">{item.issue}</span>
              <span class="date">{item.dateLabel}</span>
              <span class="rub">{formatRubric(item.rubrics[0])}</span>
              <span class="ttl">{item.title}</span>
              <span class="min">{item.readTime}</span>
              <span class="go"><span class="arrow-icon" aria-hidden="true"></span></span>
            </a>
          ))}
        </div>
        <div class="archive-foot"><span>Показано {archivePreview.length} из {archiveTotal}</span><a href="/archive/">Бездна <span class="arrow-icon arrow-down" aria-hidden="true"></span></a></div>
      </div>
    </section>

<section class="section rubrics-wrap" id="rubrics">
      <div class="section-inner"><div class="section-head"><h2 class="section-title"><span class="section-kicker">04 / таксономия</span>Рубрикатор</h2><div class="section-meta"><span>разделы</span><span class="big">{String(rubricCards.length).padStart(2, '0')}</span></div></div></div>
      <div class="rubrics">
        {rubricCards.map((rubric) => (
          <a class="rubric" href={`/rubrics/#${rubric.id}`}>
            <span class="rubric-mark">{rubric.mark}</span>
            <div class="rubric-name">{rubric.name}</div>
            <p class="rubric-desc">{rubric.desc}</p>
            <div class="rubric-meta"><span>текстов</span><span class="count">{String(rubric.count).padStart(2, '0')}</span></div>
          </a>
        ))}
      </div>
    </section>
  </main>

  <footer class="foot" id="about"><div class="foot-inner"><h2 class="foot-title">In Incerto we Trust</h2><a class="foot-cta" href="https://t.me/klb_clb" target="_blank" rel="noopener">Подписаться @klb_clb <span class="arrow-icon" aria-hidden="true"></span></a><div class="foot-meta"><div class="foot-credits"><p>© <a href="https://www.google.com/search?q=%D0%9D%D0%B8%D0%BA%D0%B8%D1%82%D0%B0+%D0%9A%D0%BE%D0%BB%D0%B1%D0%BE%D0%B2%D1%81%D0%BA%D0%B8%D0%B9" target="_blank" rel="noopener">Никита Колбовский</a> 2026. Все права защищены</p><p>Разработка: <a href="https://kolbovskiy.com" target="_blank" rel="noopener">kolbovskiy.com</a></p></div><span class="age-mark">18+</span></div><div class="foot-bottom"><span>KOLBOVSKIY.CLUB</span><a href="/rss/">RSS</a></div></div></footer>

  <script>
    (function(){
      const body = document.body;
      const menuBtn = document.getElementById('menuToggle');
      const menuLinks = document.querySelectorAll('.mobile-panel a');
      const searchOpen = document.getElementById('searchOpen');
      const mobileSearchOpen = document.getElementById('mobileSearchOpen');
      const searchClose = document.getElementById('searchClose');
      const searchInput = document.getElementById('searchInput');
      const searchResults = document.getElementById('searchResults');
      const searchIndexNode = document.getElementById('searchIndex');
      const fill = document.getElementById('progressFill');
      let searchItems = [];

      try {
        searchItems = searchIndexNode ? JSON.parse(searchIndexNode.textContent || '[]') : [];
      } catch {
        searchItems = [];
      }

      function escapeHtml(value){
        return String(value || '')
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#039;');
      }

      function normalizeSearch(value){
        return String(value || '').trim().toLowerCase().replace(/ё/g, 'е');
      }

      function renderSearch(query = ''){
        if(!searchResults) return;

        const normalized = normalizeSearch(query);
        const pool = normalized
          ? searchItems.filter(item => normalizeSearch(item.haystack).includes(normalized)).slice(0, 8)
          : searchItems.slice(0, 5);

        if(!pool.length){
          searchResults.innerHTML = '<div class="search-empty">ничего не найдено · попробуй другой сигнал</div>';
          return;
        }

        searchResults.innerHTML = pool.map(item => `
          <a class="search-result" href="${escapeHtml(item.href)}">
            <span>${escapeHtml(item.issue)}</span>
            <span class="rub">${escapeHtml(item.rubric)}</span>
            <b>${escapeHtml(item.label)}</b>
            <span class="go"><span class="search-triangle" aria-hidden="true"></span></span>
          </a>
        `).join('');
      }
      let navRevealTimer;

      function closeMenu(){
        body.classList.remove('menu-open');
      }
      function openSearch(event){
        if(event) event.preventDefault();
        closeMenu();
        body.classList.add('search-open');
        renderSearch(searchInput ? searchInput.value : '');
        window.setTimeout(() => searchInput && searchInput.focus(), 60);
      }
      function closeSearch(){ body.classList.remove('search-open'); }

      function hideNavWhileScrolling(){
        if(window.innerWidth <= 760){
          body.classList.remove('nav-is-scrolling');
          body.classList.remove('nav-row-hidden');
          return;
        }

        body.classList.add('nav-is-scrolling');
        window.clearTimeout(navRevealTimer);
        navRevealTimer = window.setTimeout(() => {
          body.classList.remove('nav-is-scrolling');
          body.classList.remove('nav-row-hidden');
        }, 620);
      }

      function updateProgress(){
        if(!fill) return;
        const root = document.documentElement;
        const max = Math.max(root.scrollHeight - window.innerHeight, 1);
        const passed = Math.min(Math.max(window.scrollY || root.scrollTop || 0, 0), max);
        fill.style.width = `${(passed / max) * 100}%`;
      }

      ['scroll','wheel','touchmove'].forEach(eventName => {
        window.addEventListener(eventName, () => {
          hideNavWhileScrolling();
          updateProgress();
        }, { passive:true });
      });

      window.addEventListener('keydown', event => {
        if(['ArrowDown','ArrowUp','PageDown','PageUp','Home','End',' '].includes(event.key)) {
          hideNavWhileScrolling();
        }
      });

      window.addEventListener('resize', () => {
        if(window.innerWidth <= 760){
          body.classList.remove('nav-is-scrolling');
          body.classList.remove('nav-row-hidden');
        }
        updateProgress();
      });

      if(menuBtn){ menuBtn.addEventListener('click', () => {
        body.classList.toggle('menu-open');
      }); }
      menuLinks.forEach(link => link.addEventListener('click', closeMenu));
      if(searchOpen){ searchOpen.addEventListener('click', openSearch); }
      if(mobileSearchOpen){ mobileSearchOpen.addEventListener('click', openSearch); }
      if(searchClose){ searchClose.addEventListener('click', closeSearch); }
      if(searchInput){ searchInput.addEventListener('input', () => renderSearch(searchInput.value)); }
      renderSearch('');
      window.addEventListener('keydown', event => {
        if(event.key === 'Escape'){
          closeMenu();
          closeSearch();
        }
      });

      updateProgress();
    })();
  </script>
</body>
</html>
