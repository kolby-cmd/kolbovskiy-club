  @media(min-width:761px) and (max-width:980px){
    .abyss-head,.abyss-row{grid-template-columns:56px 104px minmax(0,1fr) 84px 32px;gap:10px}
    .abyss-head span:nth-child(2),
    .abyss-head span:nth-child(5),
    .abyss-date{display:none}
    .abyss-rubric{grid-column:2;grid-row:1 / span 2;align-self:center;font-size:10px}
