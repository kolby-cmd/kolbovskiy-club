    .abyss-random:before{left:3px;filter:blur(14px);animation-duration:var(--motion-wave-b)}
    .abyss-random .abyss-triangle{transform:translateX(-4px)}
    .abyss-random:hover .abyss-triangle{transform:translateX(0)}

    .signal-grid{grid-template-columns:1fr}
