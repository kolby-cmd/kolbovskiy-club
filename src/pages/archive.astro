---
import { buildJsonLdGraph, KOLBOVSKIY_CLUB_WEBSITE_ID, KOLBOVSKIY_PERSON_ID } from '../data/siteEntity';
import SiteLayout from '../layouts/SiteLayout.astro';
import { articles } from '../data/articles';

const page = {
  seoTitle: 'Бездна — полный архив kolbovskiy.club',
  description: 'Полный архив kolbovskiy.club: авторские тексты, рубрики, связи и сигналы о технологиях, рынках, культуре, путешествиях и сбоях системы.',
  canonical: 'https://kolbovskiy.club/archive/'
};

const articleList = articles.filter(Boolean);
const byDateDesc = [...articleList].sort((a, b) => new Date(b.datetime).getTime() - new Date(a.datetime).getTime());
const stripHtml = (value = '') => value.replace(/<br\s*\/?>/gi, ' ').replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();
const articleHref = (article) => `/txt/${article.slug}/`;
const formatRubric = (rubric = '') => rubric.replace('#', '');
const topicsLine = (article) => article.topics.slice(0, 3).join(' / ') || stripHtml(article.deckHtml) || article.rubrics.map(formatRubric).join(' / ');

const getArticleYear = (article) => {
  const candidates = [article.datetime, article.date, article.dateLabel].filter(Boolean).map(String);
  for (const value of candidates) {
    const match = value.match(/(?:^|\D)((?:19|20)\d{2})(?:\D|$)/);
    if (match) return match[1];
  }
  return '';
};

const uniqueYears = [...new Set(articleList.map(getArticleYear).filter(Boolean))];

const pluralRu = (count, forms) => {
  const value = Math.abs(Number(count));
  const mod100 = value % 100;
  const mod10 = value % 10;
  if (mod100 >= 11 && mod100 <= 14) return forms[2];
  if (mod10 === 1) return forms[0];
  if (mod10 >= 2 && mod10 <= 4) return forms[1];
  return forms[2];
};

const formatMaterialCount = (count) => `${String(count).padStart(2, '0')} ${pluralRu(count, ['материал', 'материала', 'материалов'])}`;

const rubricConfigs = [
  { tag: '#МЛРМ', label: 'МЛРМ' },
  { tag: '#WAYAWAY', label: 'WAYAWAY' },
  { tag: '#красивое', label: 'красивое' },
  { tag: '#намолнии', label: 'намолнии' },
  { tag: '#душетушка', label: 'душетушка' },
  { tag: '#WIMM', label: 'WIMM' }
];

const activeRubrics = rubricConfigs.map((rubric) => ({
  ...rubric,
  count: articleList.filter((article) => article.rubrics.includes(rubric.tag)).length
}));

const uniqueRubrics = rubricConfigs.map((rubric) => rubric.tag);

const stats = { total: String(articleList.length).padStart(3, '0'), years: String(uniqueYears.length).padStart(2, '0'), rubrics: String(uniqueRubrics.length).padStart(2, '0') };

const rubricControls = [
  { label: 'Все', value: 'all' },
  ...activeRubrics.map((rubric) => ({ label: `${rubric.label} · ${String(rubric.count).padStart(2, '0')}`, value: rubric.label }))
];

const sortControls = [
  { label: 'Новые сверху', value: 'new' },
  { label: 'Старые сверху', value: 'old' },
  { label: 'Короткие', value: 'short' },
  { label: 'Длинные', value: 'long' }
];

const viewControls = [
  { label: 'Таблица', value: 'table' },
  { label: 'Сигналы', value: 'signals' }
];

const defaultArchiveState = { rubric: 'all', sort: 'new', view: 'table' };
const archiveHashByView = { table: '', signals: 'signals-title' };
const allowedSortValues = new Set(sortControls.map((item) => item.value));
const allowedViewValues = new Set(viewControls.map((item) => item.value));
const allowedRubricValues = new Set(rubricControls.map((item) => item.value));
const archiveParams = Astro.url.searchParams;
const requestedRubric = archiveParams.get('rubric') ?? defaultArchiveState.rubric;
const requestedSort = archiveParams.get('sort') ?? defaultArchiveState.sort;
const requestedView = archiveParams.get('view') ?? defaultArchiveState.view;
const currentArchiveState = {
  rubric: allowedRubricValues.has(requestedRubric) ? requestedRubric : defaultArchiveState.rubric,
  sort: allowedSortValues.has(requestedSort) ? requestedSort : defaultArchiveState.sort,
  view: allowedViewValues.has(requestedView) ? requestedView : defaultArchiveState.view
};
const buildArchiveHref = (patch = {}) => {
  const state = { ...currentArchiveState, ...patch };
  const params = new URLSearchParams();
  if (state.rubric !== defaultArchiveState.rubric) params.set('rubric', state.rubric);
  if (state.sort !== defaultArchiveState.sort) params.set('sort', state.sort);
  if (state.view !== defaultArchiveState.view) params.set('view', state.view);
  const query = params.toString();
  const hash = archiveHashByView[state.view] ?? archiveHashByView.table;
  return `/archive/${query ? `?${query}` : ''}${hash ? `#${hash}` : ''}`;
};

const archive = byDateDesc.map((article) => {
  const rubrics = article.rubrics.map(formatRubric);
  const timestamp = new Date(article.datetime ?? article.date).getTime();
  const readValue = Number.parseInt(String(article.readTime), 10) || 0;
  return {
    year: getArticleYear(article),
    no: article.issue,
    date: article.dateLabel,
    rubric: rubrics.join(' / '),
    rubrics,
    title: article.title,
    link: articleHref(article),
    relation: topicsLine(article),
    read: article.readTime,
    readValue,
    timestamp: Number.isFinite(timestamp) ? timestamp : 0
  };
});

const compareArchiveRows = (sort) => (a, b) => {
  if (sort === 'old') return (a.timestamp || 0) - (b.timestamp || 0);
  if (sort === 'short') return (a.readValue || 0) - (b.readValue || 0) || (b.timestamp || 0) - (a.timestamp || 0);
  if (sort === 'long') return (b.readValue || 0) - (a.readValue || 0) || (b.timestamp || 0) - (a.timestamp || 0);
  return (b.timestamp || 0) - (a.timestamp || 0);
};

const visibleArchive = archive
  .filter((item) => item.year)
  .filter((item) => currentArchiveState.rubric === 'all' || item.rubrics.includes(currentArchiveState.rubric))
  .sort(compareArchiveRows(currentArchiveState.sort));

const groupedArchive = visibleArchive.reduce((acc, item) => {
  if (!acc[item.year]) acc[item.year] = [];
  acc[item.year].push(item);
  return acc;
}, {});

const nodes = [
  ['Мировые проекты', 'Лебедьрак / Тайвань / Южная Азия / будущие карты'],
  ['Markets & Madness', 'крипта / долг / жадность / фрикономика'],
  ['Information & Intelligence', 'информация / разведка / нарратив / источник'],
  ['Beautiful Systems', 'изображение / архитектура / CG / кино'],
  ['Body & Permission', 'тело / платформа / предел / дозволенное'],
  ['Cinema Machines', 'сериалы / миф / Америка / культурный код']
];

const signalPool = byDateDesc.map((article) => [stripHtml(article.pullQuote ?? article.thesis), `${article.title}, ${article.issue}`, articleHref(article)]).filter(([quote]) => quote.length > 0);
const visibleSignalCount = 3;
const signals = signalPool.slice(0, visibleSignalCount);
const entryArticle = articleList.find((article) => article.slug === 'information') ?? byDateDesc[0];

const jsonLd = buildJsonLdGraph({
  '@type': 'CollectionPage',
  '@id': `${page.canonical}#webpage`,
  name: page.seoTitle,
  description: page.description,
  url: page.canonical,
  inLanguage: 'ru',
  isPartOf: { '@id': KOLBOVSKIY_CLUB_WEBSITE_ID },
  author: { '@id': KOLBOVSKIY_PERSON_ID },
  publisher: { '@id': KOLBOVSKIY_PERSON_ID },
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: archive.length,
    itemListElement: archive.map((item, index) => ({ '@type': 'ListItem', position: index + 1, name: item.title, url: item.link.startsWith('/') ? `https://kolbovskiy.club${item.link}` : undefined }))
  }
});
---
<style is:global>
  .abyss-page{
    --abyss-header:58px;
    --abyss-side-col:clamp(280px,24vw,340px);
    --archive-bleed: 0px;
    margin-top:calc(-1 * var(--abyss-header));
    min-height:100svh;
    background:var(--white);
    padding:calc(var(--abyss-header) + clamp(64px,7.4vh,96px)) var(--pad) clamp(96px,14vh,160px);
    border-bottom:0!important;
  }

  .abyss-shell{width:100%;max-width:none;margin:0 auto}

  .abyss-hero{
    padding-bottom:clamp(30px,5vh,58px);
    border-bottom:0;
  }

  .abyss-hero-top{
    display:block;
  }

  .abyss-hero-bottom{
    display:grid;
    grid-template-columns:minmax(0,1fr) var(--abyss-side-col);
    gap:clamp(32px,6vw,96px);
    align-items:end;
    margin-top:clamp(6px,.9vw,14px);
  }

  .abyss-kicker{
    display:flex;
    align-items:center;
    gap:14px;
    margin-bottom:clamp(22px,3vh,34px);
    color:var(--red);
    font-size:11px;
    line-height:1;
    letter-spacing:.18em;
    text-transform:uppercase;
  }

  .abyss-title{
    margin:0;
    font-family:var(--font-display)!important;
    font-size:clamp(72px,10.4vw,168px);
    line-height:.84;
    letter-spacing:-.02em;
    font-weight:400;
    text-transform:uppercase;
    color:var(--red);
  }

  .abyss-lede{
    width:min(720px,100%);
    margin-top:0;
    color:var(--black);
    font-family:var(--font-ui)!important;
    font-size:clamp(16px,1.15vw,18px);
    line-height:1.72;
    text-wrap:pretty;
  }

  .abyss-lede p{margin:0}
  .abyss-lede p+p{margin-top:1.25em}

  .abyss-count{
    display:grid;
    width:100%;
    grid-template-columns:1fr;
    gap:18px;
    margin:0;
    align-self:end;
    padding-top:10px;
    border-top:1px solid var(--line);
    transform:none;
  }

  .abyss-count__label{
    color:var(--gray);
    font-size:11px;
    line-height:1.2;
    letter-spacing:.18em;
    text-transform:uppercase;
  }

  .abyss-count__num{
    font-family:var(--font-display)!important;
    color:var(--red);
    font-size:clamp(52px,5.6vw,82px);
    line-height:.78;
    letter-spacing:-.02em;
  }

  .abyss-count__grid{
    display:grid;
    grid-template-columns:1fr 1fr;
    border-top:1px solid var(--line);
    border-bottom:1px solid var(--line);
  }

  .abyss-count__cell{
    padding:14px 0;
    color:var(--gray);
    font-size:10px;
    line-height:1.25;
    letter-spacing:.14em;
    text-transform:uppercase;
  }

  .abyss-count__cell+.abyss-count__cell{border-left:1px solid var(--line);padding-left:18px}
  .abyss-count__cell b{display:block;margin-top:6px;color:var(--black);font-weight:700;font-size:14px;letter-spacing:.08em}

  .abyss-panel{
    display:grid;
    grid-template-columns:minmax(140px,.24fr) minmax(0,1fr);
    gap:0;
    margin:clamp(36px,5.5vh,64px) 0 clamp(44px,6.5vh,76px);
    border-top:1px solid var(--black);
    border-bottom:1px solid var(--black);
  }

  .abyss-panel__label{
    padding:18px 20px 18px 0;
    border-bottom:1px solid var(--line);
    color:var(--red);
    font-size:10px;
    line-height:1;
    letter-spacing:.18em;
    text-transform:uppercase;
    font-weight:700;
  }

  .abyss-panel__row{
    display:flex;
    flex-wrap:wrap;
    gap:10px 14px;
    padding:14px 0 14px 20px;
    border-left:1px solid var(--line);
    border-bottom:1px solid var(--line);
  }

  .abyss-panel__label:nth-last-child(2),
  .abyss-panel__row:last-child{border-bottom:0}

  .abyss-chip{
    position:relative;
    appearance:none;
    border:0;
    background:transparent;
    min-height:24px;
    padding:0;
    display:inline-flex;
    align-items:center;
    color:var(--black);
    font-size:10px;
    line-height:1.2;
    letter-spacing:.12em;
    text-transform:uppercase;
    cursor:pointer;
    text-decoration:none;
    transition:color var(--motion-ui) var(--ease),transform var(--motion-ui) var(--ease);
  }

  .abyss-chip:hover{color:var(--red);transform:translateX(2px)}
  .abyss-chip.is-active{color:var(--red);font-weight:700}
  .abyss-chip.is-red{color:var(--red);font-weight:700}

  .abyss-main{
    display:grid;
    grid-template-columns:minmax(0,1fr) var(--abyss-side-col);
    gap:clamp(38px,5vw,72px);
    align-items:start;
  }

  .abyss-register{min-width:0}

  .abyss-year{
    display:grid;
    grid-template-columns:minmax(0,1fr) auto;
    gap:24px;
    align-items:end;
    margin:0 0 22px;
    padding-bottom:14px;
    border-bottom:1px solid var(--black);
  }

  .abyss-year-block + .abyss-year-block{margin-top:clamp(82px,10vh,132px)}

  .abyss-year__title{
    font-family:var(--font-display)!important;
    font-size:82px;
    line-height:.86;
    font-weight:400;
    letter-spacing:-.015em;
    color:var(--red);
  }

  .abyss-year__count{
    color:var(--gray);
    font-size:11px;
    line-height:1;
    letter-spacing:.16em;
    text-transform:uppercase;
  }

  .abyss-head,
  .abyss-row{
    display:grid;
    grid-template-columns:62px 94px 110px minmax(0,1fr) 92px 40px;
    gap:14px;
    align-items:center;
  }

  .abyss-head{
    padding:0 0 12px;
    color:var(--gray);
    font-size:10px;
    line-height:1;
    letter-spacing:.16em;
    text-transform:uppercase;
  }

  .abyss-head span:nth-child(5){display:none}
  .abyss-head span:nth-child(6),
  .abyss-head span:nth-child(7){text-align:right;white-space:nowrap}

  .abyss-row{
    position:relative;
    overflow:hidden;
    padding:18px 0;
    border-top:1px solid var(--line);
    row-gap:6px;
  }

  .abyss-row:last-child{border-bottom:1px solid var(--line)}

  .abyss-row:before{
    content:"";
    position:absolute;
    left:0;
    top:0;
    bottom:0;
    width:100%;
    background:linear-gradient(90deg,transparent 0%,rgba(209,11,11,.10) 25%,rgba(209,11,11,.20) 100%);
    transform:translateX(-100%);
    transition:transform var(--motion-sweep) var(--ease);
    pointer-events:none;
  }

  .abyss-row:hover:before{transform:translateX(0)}
  .abyss-row>*{position:relative;z-index:1}

  .abyss-no{color:var(--red);font-weight:700;font-size:13px;letter-spacing:.08em;text-transform:uppercase}
  .abyss-date,.abyss-rubric,.abyss-link,.abyss-read{color:var(--gray);font-size:11px;letter-spacing:.12em;text-transform:uppercase}
  .abyss-read{white-space:nowrap}
  .abyss-rubric{color:var(--red)}
  .abyss-title-row{min-width:0;color:var(--black);font-weight:500;font-size:14px;line-height:1.35;transition:transform var(--motion-hover) var(--ease)}
  .abyss-relation{min-width:0;color:var(--gray);font-size:11px;line-height:1.35;letter-spacing:.03em;text-transform:none;overflow-wrap:anywhere;word-break:normal}
  .abyss-read,.abyss-link{text-align:right}
  .abyss-title-row{grid-column:4;grid-row:1;min-width:0}
  .abyss-relation{grid-column:4;grid-row:2;display:block;max-width:100%;min-width:0;padding-right:18px;overflow:visible}
  .abyss-read{grid-column:5;grid-row:1 / span 2;align-self:center;justify-self:end;min-width:74px}
  .abyss-link{grid-column:6;grid-row:1 / span 2;align-self:center;justify-self:end;display:flex;align-items:center;justify-content:flex-end;text-align:right;padding-right:0;overflow:visible}

  .abyss-row:hover .abyss-title-row{transform:translateX(10px)}
  .abyss-triangle{display:inline-block;width:0;height:0;border-top:6px solid transparent;border-bottom:6px solid transparent;border-left:10px solid var(--red);transform:translateX(-10px);transition:transform var(--motion-hover) var(--ease)}
  .abyss-row:hover .abyss-triangle{transform:translateX(-5px)}

  .abyss-side{
    position:sticky;
    top:112px;
    z-index:3;
    display:grid;
    gap:34px;
    width:100%;
    padding-top:calc(82px * .86 + 14px);
  }

  .abyss-card{
    border-top:1px solid var(--black);
    border-bottom:1px solid var(--black);
    padding:18px 0;
    background:var(--white);
  }

  .abyss-card__head{
    display:flex;
    justify-content:space-between;
    gap:16px;
    margin-bottom:20px;
    color:var(--red);
    font-size:10px;
    line-height:1;
    letter-spacing:.18em;
    text-transform:uppercase;
    font-weight:700;
  }

  .abyss-node{
    display:grid;
    gap:6px;
    padding:14px 0;
    border-top:1px solid var(--line);
  }

  .abyss-node:first-of-type{border-top:0}
  .abyss-node b{color:var(--black);font-size:12px;line-height:1.25;letter-spacing:.08em;text-transform:uppercase}
  .abyss-node span{color:var(--gray);font-size:11px;line-height:1.45}

  .abyss-random{
    position:relative;
    background:var(--white);
    overflow:hidden;
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:18px;
    min-height:54px;
    padding:0 18px 0 16px;
    border-left:3px solid var(--red);
    color:var(--black);
    font-size:11px;
    line-height:1.2;
    letter-spacing:.16em;
    text-transform:uppercase;
    font-weight:700;
  }

  .abyss-random:before{
    content:"";
    position:absolute;
    left:3px;
    right:-22%;
    top:-46%;
    bottom:-46%;
    background:
      linear-gradient(101deg,
        transparent 0%,
        rgba(209,11,11,0) 12%,
        rgba(209,11,11,.10) 24%,
        rgba(209,11,11,.32) 40%,
        rgba(209,11,11,.18) 56%,
        rgba(209,11,11,0) 76%,
        transparent 100%),
      radial-gradient(ellipse 54% 92% at 24% 52%, rgba(209,11,11,.30) 0%, rgba(209,11,11,.12) 42%, transparent 78%),
      radial-gradient(ellipse 70% 120% at 74% 45%, rgba(209,11,11,.24) 0%, rgba(209,11,11,.10) 45%, transparent 82%),
      linear-gradient(118deg, transparent 0%, rgba(209,11,11,.08) 30%, rgba(209,11,11,.20) 48%, rgba(209,11,11,0) 70%, transparent 100%);
    background-size:300% 100%, 260% 150%, 320% 170%, 360% 100%;
    background-position:-180% 50%, -150% 50%, 170% 44%, -210% 50%;
    filter:blur(20px);
    opacity:.58;
    animation:abyssWave var(--motion-wave-a) cubic-bezier(.46,.03,.22,1) infinite;
    pointer-events:none;
  }

  .abyss-random:hover:before{opacity:.74}

  .abyss-random span{position:relative;z-index:1}
  .abyss-random .abyss-triangle{transform:translateX(-10px)}
  .abyss-random:hover .abyss-triangle{transform:translateX(-4px)}



  @keyframes abyssWave{
    0%{background-position:-182% 52%, -154% 50%, 172% 44%, -212% 50%; opacity:.34}
    25%{background-position:-76% 47%, -72% 56%, 104% 48%, -96% 46%; opacity:.66}
    50%{background-position:18% 55%, 20% 45%, 22% 53%, 18% 58%; opacity:.52}
    75%{background-position:96% 49%, 118% 57%, -60% 46%, 110% 44%; opacity:.70}
    100%{background-position:196% 52%, 184% 50%, -190% 50%, 210% 50%; opacity:.36}
  }

  .abyss-random{isolation:isolate}


  .abyss-signals{
    margin-top:clamp(54px,8vh,92px);
    padding-top:clamp(34px,5.5vh,58px);
    border-top:1px solid var(--black);
  }

  .abyss-section-head{
    display:grid;
    grid-template-columns:1fr auto;
    gap:24px;
    align-items:start;
    margin-bottom:clamp(34px,5vh,54px);
  }

  .abyss-section-title{
    font-family:var(--font-display)!important;
    font-size:82px;
    line-height:.86;
    letter-spacing:-.012em;
    font-weight:400;
    text-transform:uppercase;
  }

  .abyss-section-count{
    font-family:var(--font-display)!important;
    color:var(--red);
    font-size:52px;
    line-height:.9;
    letter-spacing:0;
    font-weight:400;
  }


  .signal-tools{
    display:flex;
    flex-direction:column;
    align-items:flex-end;
    justify-content:flex-start;
    gap:2px;
    align-self:start;
    padding-top:0;
    transform:translateY(-2px);
  }

  .signal-shuffle{
    appearance:none;
    border:0;
    background:transparent;
    min-height:0;
    padding:0;
    color:var(--black);
    font-family:var(--font-ui)!important;
    font-size:10px;
    line-height:1;
    letter-spacing:.14em;
    text-transform:uppercase;
    cursor:pointer;
  }

  .signal-shuffle:hover{color:var(--red)}

  .abyss-signals-note{
    max-width:720px;
    margin:-10px 0 28px;
    color:var(--gray);
    font-size:14px;
    line-height:1.55;
    font-style:italic;
  }

  .signal-grid{
    display:grid;
    grid-template-columns:repeat(3,minmax(0,1fr));
    border-top:1px solid var(--line);
    border-bottom:1px solid var(--line);
  }

  .signal-item{
    min-height:190px;
    padding:24px 22px 20px;
    border-right:1px solid var(--line);
    display:flex;
    text-decoration:none;
    color:inherit;
    flex-direction:column;
    justify-content:space-between;
    gap:22px;
  }

  .signal-item:last-child{border-right:0}
  .signal-item blockquote{font-family:var(--font-display)!important;color:var(--black);font-size:clamp(24px,2.55vw,38px);line-height:1.02;letter-spacing:-.008em;text-transform:uppercase}
  .signal-item cite{color:var(--gray);font-style:normal;font-size:10px;line-height:1.3;letter-spacing:.18em;text-transform:uppercase}



  @media(min-width:761px) and (max-width:1320px){
    .abyss-hero-bottom{margin-top:clamp(24px,3.2vw,42px)}
    .abyss-title{font-size:clamp(76px,13vw,148px)}
