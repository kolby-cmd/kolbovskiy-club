    .abyss-year{grid-template-columns:1fr;gap:10px;margin-bottom:20px}
    .abyss-year__title{font-size:64px}
    .abyss-year-block + .abyss-year-block{margin-top:92px}
    .abyss-head{display:none}
    .abyss-row{grid-template-columns:54px 1fr 34px;gap:14px;padding:16px 0}
    .abyss-date,.abyss-rubric,.abyss-read,.abyss-relation{display:none}
    .abyss-title-row{font-size:14px}
    .abyss-row:hover .abyss-title-row{transform:translateX(6px)}

    .abyss-side{
      grid-template-columns:minmax(0,1fr) minmax(0,1fr);
      gap:14px;
      align-items:stretch;
      padding-top:42px;
      border-top:0;
      border-bottom:0;
