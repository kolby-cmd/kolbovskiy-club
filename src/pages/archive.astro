</style>
<SiteLayout title={page.seoTitle} description={page.description} canonical={page.canonical} ogType="website" current="archive" jsonLd={jsonLd}>
  <main class="abyss-page">
    <div class="abyss-shell">
      <section class="abyss-hero" aria-labelledby="abyss-title">
        <div class="abyss-hero-top">
          <div class="abyss-kicker"><span class="dot dot-pulse"></span><span>Полный архив</span></div>
          <h1 class="abyss-title" id="abyss-title">Бездна</h1>
        </div>
        <div class="abyss-hero-bottom">
          <div class="abyss-lede">
            <p>Полный слой архива kolbovskiy.club: материалы из Telegram, собранные в хронологию с рубриками, связями и точками входа. Здесь можно идти по датам, темам, рубрикам и отдельным линиям корпуса.</p>
          </div>
          <aside class="abyss-count" aria-label="Статистика архива">
            <span class="abyss-count__label">Материалов</span>
            <span class="abyss-count__num">{stats.total}</span>
            <div class="abyss-count__grid">
              <span class="abyss-count__cell">Года<b>{stats.years}</b></span>
              <span class="abyss-count__cell">Рубрик<b>{stats.rubrics}</b></span>
            </div>
          </aside>
        </div>
      </section>

      <section class="abyss-panel" aria-label="Пульт архива">
        <div class="abyss-panel__label">Режим</div>
        <div class="abyss-panel__row">
          {rubricControls.map((item) => <a class:list={['abyss-chip', { 'is-active': currentArchiveState.rubric === item.value }]} href={buildArchiveHref({ rubric: item.value, view: 'table' })} data-archive-control="rubric" data-archive-value={item.value}>[{item.label}]</a>)}
        </div>
        <div class="abyss-panel__label">Сортировка</div>
        <div class="abyss-panel__row">
          {sortControls.map((item) => <a class:list={['abyss-chip', { 'is-active': currentArchiveState.sort === item.value }]} href={buildArchiveHref({ sort: item.value, view: 'table' })} data-archive-control="sort" data-archive-value={item.value}>[{item.label}]</a>)}
        </div>
        <div class="abyss-panel__label">Форма</div>
        <div class="abyss-panel__row">
          {viewControls.map((item) => <a class:list={['abyss-chip', { 'is-active': currentArchiveState.view === item.value }]} href={buildArchiveHref({ view: item.value })} data-archive-control="view" data-archive-value={item.value}>[{item.label}]</a>)}
          <a class="abyss-chip is-red" href={articleHref(entryArticle)} data-random-entry>[Случайный вход]</a>
        </div>
      </section>

      <script type="application/json" id="archiveData" is:inline set:html={JSON.stringify(archive)}></script>

      <section class="abyss-main" aria-label="Полный архив">
        <div class="abyss-register" id="archive-register" data-archive-register>
          {Object.entries(groupedArchive).sort((a, b) => Number(b[0]) - Number(a[0])).map(([year, items]) => (
            <section class="abyss-year-block" aria-labelledby={`year-${year}`}>
              <div class="abyss-year">
                <h2 class="abyss-year__title" id={`year-${year}`}>{year}</h2>
                <span class="abyss-year__count">{formatMaterialCount(items.length)}</span>
              </div>
              <div class="abyss-head" aria-hidden="true">
                <span>№</span><span>Дата</span><span>Рубрика</span><span>Материал</span><span>Связь</span><span>Чтение</span><span></span>
              </div>
              <div class="abyss-table">
                {items.map((item) => (
                  <a class="abyss-row" href={item.link}>
                    <span class="abyss-no">{item.no}</span>
                    <span class="abyss-date">{item.date}</span>
                    <span class="abyss-rubric">{item.rubric}</span>
                    <span class="abyss-title-row">{item.title}</span>
                    <span class="abyss-relation">{item.relation}</span>
                    <span class="abyss-read">{item.read}</span>
                    <span class="abyss-link"><span class="abyss-triangle" aria-hidden="true"></span></span>
                  </a>
                ))}
              </div>
            </section>
          ))}
        </div>

        <aside class="abyss-side" id="archive-nodes" aria-label="Узлы архива">
          <section class="abyss-card">
            <div class="abyss-card__head"><span>Узлы</span><span>{String(nodes.length).padStart(2, '0')}</span></div>
            {nodes.map(([title, desc]) => (
              <div class="abyss-node">
                <b>{title}</b>
                <span>{desc}</span>
              </div>
            ))}
          </section>
          <a class="abyss-random" href={articleHref(entryArticle)} data-random-entry>
            <span>[Случайный вход]</span>
            <span class="abyss-triangle" aria-hidden="true"></span>
          </a>
        </aside>
      </section>

      <section class="abyss-signals" aria-labelledby="signals-title">
        <div class="abyss-section-head">
          <h2 class="abyss-section-title" id="signals-title">Сигналы</h2>
          <div class="signal-tools"><span class="abyss-section-count">03 / {String(signalPool.length).padStart(2, '0')}</span><button class="signal-shuffle" type="button" data-signal-shuffle>[Перемешать]</button></div>
        </div>
        <p class="abyss-signals-note">Короткие фразы из материалов архива. Они дают быстрый вход в темы, интонации и повторяющиеся мотивы корпуса.</p>
        <script type="application/json" id="signalPool" is:inline set:html={JSON.stringify(signalPool)}></script>
        <div class="signal-grid" data-signal-grid>
          {signals.map(([quote, source, link]) => (
            <a class="signal-item" href={link} data-signal-item>
              <blockquote data-signal-quote>{quote}</blockquote>
              <cite data-signal-source>— {source}</cite>
            </a>
          ))}
        </div>
      </section>
    </div>
  </main>
  <script is:inline>
    (() => {
      const pluralRu = (count, forms) => {
        const value = Math.abs(Number(count));
        const mod100 = value % 100;
        const mod10 = value % 10;
        if (mod100 >= 11 && mod100 <= 14) return forms[2];
        if (mod10 === 1) return forms[0];
        if (mod10 >= 2 && mod10 <= 4) return forms[1];
        return forms[2];
      };
      const formatMaterialCount = (count) => `${String(count).padStart(2, '0')} ${pluralRu(count, ['материал', 'материала', 'материалов'])}`;
      const dataElement = document.getElementById('archiveData');
      const register = document.querySelector('[data-archive-register]');
      const controls = Array.from(document.querySelectorAll('[data-archive-control]'));
      if (!dataElement || !register || controls.length === 0) return;

      let archiveRows = [];
      try {
        archiveRows = JSON.parse(dataElement.textContent || '[]');
      } catch (error) {
        archiveRows = [];
      }

      if (!Array.isArray(archiveRows) || archiveRows.length === 0) return;

      const randomEntryLinks = Array.from(document.querySelectorAll('[data-random-entry]'));
      const randomEntryPool = archiveRows.map((row) => row.link).filter(Boolean);

      function setRandomEntryHref(previousHref = ''){
        if (randomEntryPool.length === 0 || randomEntryLinks.length === 0) return;
        let nextHref = randomEntryPool[Math.floor(Math.random() * randomEntryPool.length)];
        if (randomEntryPool.length > 1 && nextHref === previousHref) {
          const currentIndex = randomEntryPool.indexOf(nextHref);
          const shift = 1 + Math.floor(Math.random() * (randomEntryPool.length - 1));
          nextHref = randomEntryPool[(currentIndex + shift) % randomEntryPool.length];
        }
        randomEntryLinks.forEach((link) => {
          link.setAttribute('href', nextHref);
        });
      }

      setRandomEntryHref();
      randomEntryLinks.forEach((link) => {
        link.addEventListener('pointerdown', () => setRandomEntryHref(link.getAttribute('href') || ''));
        link.addEventListener('focus', () => setRandomEntryHref(link.getAttribute('href') || ''));
      });

      const defaultState = { rubric: 'all', sort: 'new', view: 'table' };
      const hashByView = { table: '', signals: 'signals-title' };
      const allowedSorts = new Set(['new', 'old', 'short', 'long']);
      const allowedViews = new Set(['table', 'signals']);
      const allowedRubrics = new Set(['all']);
      archiveRows.forEach((row) => (row.rubrics || []).forEach((rubric) => allowedRubrics.add(rubric)));

      function getStateFromUrl(){
        const params = new URLSearchParams(window.location.search);
        const rubric = params.get('rubric');
        const sort = params.get('sort');
        let view = params.get('view');

        if (!view && window.location.hash === '#signals-title') view = 'signals';

        return {
          rubric: allowedRubrics.has(rubric) ? rubric : defaultState.rubric,
          sort: allowedSorts.has(sort) ? sort : defaultState.sort,
          view: allowedViews.has(view) ? view : defaultState.view
        };
      }

      function buildUrl(state){
        const params = new URLSearchParams();
        if (state.rubric !== defaultState.rubric) params.set('rubric', state.rubric);
        if (state.sort !== defaultState.sort) params.set('sort', state.sort);
        if (state.view !== defaultState.view) params.set('view', state.view);
        const query = params.toString();
        const hash = hashByView[state.view] || hashByView.table;
        return `${window.location.pathname}${query ? `?${query}` : ''}${hash ? `#${hash}` : ''}`;
      }

      function compareRows(sort){
        return (a, b) => {
          if (sort === 'old') return (a.timestamp || 0) - (b.timestamp || 0);
          if (sort === 'short') return (a.readValue || 0) - (b.readValue || 0) || (b.timestamp || 0) - (a.timestamp || 0);
          if (sort === 'long') return (b.readValue || 0) - (a.readValue || 0) || (b.timestamp || 0) - (a.timestamp || 0);
          return (b.timestamp || 0) - (a.timestamp || 0);
        };
      }

      function span(className, text){
        const node = document.createElement('span');
        node.className = className;
        node.textContent = text ?? '';
        return node;
      }

      function buildHead(){
        const head = document.createElement('div');
        head.className = 'abyss-head';
        head.setAttribute('aria-hidden', 'true');
        ['№', 'Дата', 'Рубрика', 'Материал', 'Связь', 'Чтение', ''].forEach((label) => {
          const item = document.createElement('span');
          item.textContent = label;
          head.appendChild(item);
        });
        return head;
      }

      function buildRow(row){
        const link = document.createElement('a');
        link.className = 'abyss-row';
        link.href = row.link || '#';
        link.appendChild(span('abyss-no', row.no));
        link.appendChild(span('abyss-date', row.date));
        link.appendChild(span('abyss-rubric', row.rubric));
        link.appendChild(span('abyss-title-row', row.title));
        link.appendChild(span('abyss-relation', row.relation));
        link.appendChild(span('abyss-read', row.read));

        const arrowCell = document.createElement('span');
        arrowCell.className = 'abyss-link';
        const triangle = document.createElement('span');
        triangle.className = 'abyss-triangle';
        triangle.setAttribute('aria-hidden', 'true');
        arrowCell.appendChild(triangle);
        link.appendChild(arrowCell);

        return link;
      }

      function renderArchive(rows){
        register.replaceChildren();

        const groups = new Map();
        rows.forEach((row) => {
          if (!groups.has(row.year)) groups.set(row.year, []);
          groups.get(row.year).push(row);
        });

        groups.forEach((items, year) => {
          const section = document.createElement('section');
          section.className = 'abyss-year-block';
          section.setAttribute('aria-labelledby', `year-${year}`);

          const yearHead = document.createElement('div');
          yearHead.className = 'abyss-year';

          const title = document.createElement('h2');
          title.className = 'abyss-year__title';
          title.id = `year-${year}`;
          title.textContent = year;

          const count = document.createElement('span');
          count.className = 'abyss-year__count';
          count.textContent = formatMaterialCount(items.length);

          yearHead.appendChild(title);
          yearHead.appendChild(count);
          section.appendChild(yearHead);
          section.appendChild(buildHead());

          const table = document.createElement('div');
          table.className = 'abyss-table';
          items.forEach((row) => table.appendChild(buildRow(row)));
          section.appendChild(table);

          register.appendChild(section);
        });
      }

      function updateActiveControls(state){
        controls.forEach((control) => {
          const group = control.dataset.archiveControl;
          const value = control.dataset.archiveValue;
          control.classList.toggle('is-active', state[group] === value);
        });
      }

      function applyState(state, shouldScroll = false){
        const rows = archiveRows
          .filter((row) => row.year)
          .filter((row) => state.rubric === 'all' || (row.rubrics || []).includes(state.rubric))
          .sort(compareRows(state.sort));

        renderArchive(rows);
        updateActiveControls(state);

        if (shouldScroll) {
          const targetId = hashByView[state.view] || hashByView.table;
          const target = targetId ? document.getElementById(targetId) : null;
          target?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      }

      let currentState = getStateFromUrl();
      applyState(currentState, false);

      controls.forEach((control) => {
        control.addEventListener('click', (event) => {
          if (event.defaultPrevented || event.metaKey || event.ctrlKey || event.shiftKey || event.altKey || event.button !== 0) return;
          event.preventDefault();

          const group = control.dataset.archiveControl;
          const value = control.dataset.archiveValue;
          const nextState = { ...currentState, [group]: value };
          if (group !== 'view') nextState.view = 'table';

          currentState = nextState;
          window.history.pushState(currentState, '', buildUrl(currentState));
          applyState(currentState, group === 'view' && value !== 'table');
        });
      });

      window.addEventListener('popstate', () => {
        currentState = getStateFromUrl();
        applyState(currentState, false);
      });
    })();

    (() => {
      const poolElement = document.getElementById('signalPool');
      const cards = Array.from(document.querySelectorAll('[data-signal-item]'));
      const shuffleButton = document.querySelector('[data-signal-shuffle]');
      if (!poolElement || cards.length === 0 || !shuffleButton) return;

      let pool = [];
      try {
        pool = JSON.parse(poolElement.textContent || '[]');
      } catch (error) {
        pool = [];
      }

      if (!Array.isArray(pool) || pool.length <= cards.length) return;

      function shuffledSignals(){
        const copy = [...pool];
        for (let index = copy.length - 1; index > 0; index -= 1) {
          const nextIndex = Math.floor(Math.random() * (index + 1));
          [copy[index], copy[nextIndex]] = [copy[nextIndex], copy[index]];
        }
        return copy.slice(0, cards.length);
      }

      function shuffleSignals(){
        const next = shuffledSignals();
        cards.forEach((card, index) => {
          const quote = card.querySelector('[data-signal-quote]');
          const source = card.querySelector('[data-signal-source]');
          const item = next[index];
          if (!quote || !source || !item) return;
          quote.textContent = item[0];
          source.textContent = `— ${item[1]}`;
          if (item[2]) card.setAttribute('href', item[2]);
        });
      }

      shuffleButton.addEventListener('click', shuffleSignals);
    })();
  </script>

</SiteLayout>
