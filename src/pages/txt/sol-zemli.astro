---
import SiteLayout from '../../layouts/SiteLayout.astro';

const article = {
  title: 'Соль Земли',
  seoTitle: 'Соль Земли — Индия, бедность и коллективная мощь | kolbovskiy.club',
  description: 'Полевой текст из Индии о людях, которые почти не попадают в новости, но каждый день собирают собой экономику, улицу, транспорт, еду и фактуру Реального мира.',
  date: '2026-03-09',
  dateLabel: '09.03.2026',
  dateLong: '9 марта 2026',
  timeLabel: '00 : 22',
  dateDisplay: '9 марта 2026, пн, 00 : 22',
  issue: '№041',
  rubrics: ['#МЛРМ', '#wayaway'],
  readTime: '8 мин',
  heroImage: '/assets/test.jpg',
  telegramUrl: 'https://t.me/klb_clb',
  excerpt: 'Индия — заметки о рабочей массе, бедности и коллективной мощности.',
  thesis: 'Бедность здесь индивидуальна, а мощь — коллективна.',
  archiveReason: 'Этот текст фиксирует одну из базовых тем канала: как низовая бедность, труд, улица и масса людей собираются в макроэкономическую силу.',
  place: 'Мадурай — Мадрас',
  form: 'полевая колонка',
  source: 'Telegram / @klb_clb',
  canonical: 'https://kolbovskiy.club/txt/sol-zemli/',
  author: 'Никита Колбовский',
  topics: ['Индия', 'бедность', 'массовая экономика', 'повседневность'],
  status: 'в архиве',
  related: [
    {
      issue: '№039',
      date: '22.08.2025',
      rubric: 'МЛРМ',
      title: 'Думай, что в стакане вода. Дуров у Фридмана',
      reason: 'Связь: человек внутри системы и публичная наивность перед большой машиной.',
      readTime: '6 мин',
      href: '/archive/'
    },
    {
      issue: '№040',
      date: '22.09.2025',
      rubric: 'МЛРМ',
      title: 'Ликвидация жадности',
      reason: 'Связь: рынки, масса, желание и коллективная механика поведения.',
      readTime: '4 мин',
      href: '/archive/'
    },
    {
      issue: '№037',
      date: '03.06.2025',
      rubric: 'WAYAWAY',
      title: 'Бурунди — Бруней',
      reason: 'Связь: взгляд с земли на места, которые обычно существуют только как названия.',
      readTime: '7 мин',
      href: '/archive/'
    }
  ]
};

const absoluteHeroImage = new URL(article.heroImage, article.canonical).toString();

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: article.title,
  name: article.title,
  description: article.description,
  datePublished: article.date,
  dateModified: article.date,
  inLanguage: 'ru',
  isAccessibleForFree: true,
  mainEntityOfPage: article.canonical,
  url: article.canonical,
  author: {
    '@type': 'Person',
    name: article.author,
    url: 'https://www.kolbovskiy.com/'
  },
  publisher: {
    '@type': 'Organization',
    name: 'kolbovskiy.club',
    url: 'https://kolbovskiy.club/'
  },
  image: absoluteHeroImage
};

---
<SiteLayout title={article.seoTitle} description={article.description} canonical={article.canonical} ogType="article" ogImage={article.heroImage} current="archive" jsonLd={jsonLd}>
  <style slot="pageStyles">#articleTop{margin-top:-58px;padding-top:92px;background:var(--white);position:relative;z-index:2}.article-mast{position:relative;overflow:visible;background:var(--white);border-bottom:0;min-height:0!important;height:auto!important}
    .article-mast:before,.article-mast:after,.hero-wrap:before,.hero-wrap:after,.article-kicker:before,.article-kicker:after{content:none!important;display:none!important}
    .issue-line{position:relative;z-index:2;display:flex;gap:10px;align-items:baseline;flex-wrap:wrap;padding:16px var(--pad);border-bottom:1px solid var(--black);font-size:11px;line-height:1.25;letter-spacing:.12em;background:rgba(240,237,230,.44)}
    .issue-line .no{color:var(--red);font-weight:700;font-size:13px;letter-spacing:.06em;text-transform:uppercase}
    .issue-line .sep{color:var(--faint)}
    .issue-line .meta{color:var(--muted);text-transform:none}
    .issue-line .read{color:var(--muted);text-transform:uppercase;margin-left:auto;text-align:right;white-space:nowrap}
    .issue-line .read b{color:var(--black);font-weight:700}
    .hero-wrap{position:relative!important;z-index:1;width:auto!important;max-width:none!important;min-height:0!important;height:auto!important;margin:0!important;padding:clamp(34px,5.6vh,68px) var(--pad) clamp(44px,7vh,84px)!important;background:transparent!important;border:0!important;box-shadow:none!important}
    .article-kicker{position:relative!important;left:auto!important;right:auto!important;top:auto!important;bottom:auto!important;transform:none!important;display:inline-flex!important;align-items:center!important;gap:10px!important;width:auto!important;max-width:100%!important;height:auto!important;min-height:0!important;padding:0!important;margin:0 0 clamp(28px,4.8vh,54px)!important;background:transparent!important;border:0!important;box-shadow:none!important;color:var(--red);font-size:11px;line-height:1;letter-spacing:.14em;text-transform:uppercase;white-space:normal;pointer-events:auto}
    .article-kicker__dot{display:inline-block!important;width:7px!important;height:7px!important;min-width:7px!important;min-height:7px!important;border-radius:50%;background:var(--red);animation:pulse 1.8s infinite;flex:0 0 auto;transform:none!important}
    .article-kicker .article-rubric{display:inline!important;color:var(--red);font-weight:700;background:transparent!important;border:0!important;padding:0!important;margin:0!important;min-height:0!important;height:auto!important;width:auto!important;flex:0 1 auto!important;line-height:1}
    .h-title{font-family:var(--font-display);color:var(--red);font-weight:400;font-size:clamp(72px,10.4vw,168px);line-height:.84;letter-spacing:-.02em;margin:0 0 clamp(18px,2.6vh,32px);max-width:14ch;text-transform:uppercase}
    .h-title .word{display:inline-block;opacity:0;transform:translateY(20px);animation:wordIn 1s var(--ease) both}
    .h-title .word:nth-child(1){animation-delay:.10s}.h-title .word:nth-child(2){animation-delay:.22s}.h-title .word:nth-child(3){animation-delay:.34s}
    @keyframes wordIn{to{opacity:1;transform:translateY(0)}}
    .h-deck{max-width:47ch;margin:0;color:var(--muted);font-style:italic;font-size:clamp(15px,1.15vw,18px);line-height:1.5}
    .h-byline{display:grid;grid-template-columns:auto 1fr auto;gap:clamp(20px,4vw,80px);align-items:end;padding-top:18px;border-top:1px solid var(--line);font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--muted)}
    .h-byline .lbl{color:var(--faint);display:block;margin-bottom:5px}.h-byline .val{color:var(--black);font-weight:700}.h-byline .credit{text-align:right}

    .cover-wrap{margin:0 var(--pad) clamp(10px,1.8vh,18px)}
    .cover{position:relative;overflow:visible;background:transparent;border:0}
    .cover:before,.cover:after{display:none}
    .cover-img{display:block;width:100%;height:auto;border:0}
    .cover-caption{width:auto;max-width:none;margin:8px 0 0;color:var(--faint);font-size:10px;line-height:1.32;letter-spacing:.12em;text-transform:uppercase;text-align:right}

    /* ARTICLE TEXT — outer gutters always use global --pad, same as index */
    .article{display:grid;grid-template-columns:minmax(var(--pad),1fr) minmax(0,var(--col)) minmax(var(--pad),1fr);column-gap:0;padding:clamp(64px,10vh,128px) 0 clamp(28px,5vh,54px)}
    .article>*{grid-column:2}
    .p{font-size:clamp(16px,1.15vw,18px);line-height:1.72;color:var(--black);margin:0 0 1.25em;text-wrap:pretty;hyphens:auto}
    .p em{font-style:italic}.p strong{font-weight:700}
    .dropcap{float:left;font-family:var(--font-display);color:var(--red);font-size:clamp(96px,12vw,156px);line-height:.82;margin:6px 14px 0 -4px;letter-spacing:-.04em}
    .p-marker{position:relative}
    .p-marker:before{content:attr(data-mark);position:absolute;left:calc(-1*(var(--pad) + 4px));top:.35em;transform:translateX(-100%);width:80px;text-align:right;color:var(--red);opacity:.75;font-size:10px;letter-spacing:.16em}
    .pull{grid-column:1/-1;display:flex;justify-content:center;padding:clamp(40px,8vh,80px) var(--pad)}
    .pull blockquote{font-family:var(--font-display);max-width:24ch;color:var(--black);text-align:center;text-transform:uppercase;font-size:clamp(44px,6.2vw,104px);line-height:.94;letter-spacing:-.014em;font-weight:400;text-wrap:balance;position:relative}
    .pull blockquote:before{content:"«";position:absolute;left:-.6em;top:-.38em;color:var(--red);font-size:1.2em;line-height:1}
    .pull blockquote .qtxt:after{content:"»";color:var(--red);margin-left:.05em}
    .brk{display:flex;gap:14px;align-items:center;justify-content:center;margin:clamp(28px,4vh,48px) 0;color:var(--faint);font-size:11px;letter-spacing:.26em;text-transform:uppercase}
    .brk .line{display:block;width:56px;height:1px;background:var(--black)}.brk .num{color:var(--red);font-weight:700}
    .fn{color:var(--red);vertical-align:super;font-size:.72em;padding:0 2px;text-decoration:none}
    .sig{margin-top:clamp(40px,6vh,72px);padding-top:0;border-top:0;display:flex;gap:10px;align-items:center;flex-wrap:wrap;color:var(--muted)}
    .sig-skull{display:inline-block;width:22px;height:22px;border:0;border-radius:0;background:url('/assets/apple-touch-icon_red.png') center/contain no-repeat;transform:none;flex:0 0 auto}
    .sig .dash{color:var(--black);font-weight:700}.sig .name{color:var(--black);font-weight:700}.sig .tg{color:var(--red);font-weight:700}

    .notes{display:grid;grid-template-columns:minmax(var(--pad),1fr) minmax(0,var(--col)) minmax(var(--pad),1fr);column-gap:0;padding:0 0 clamp(46px,7vh,84px)}
    .notes-inner{grid-column:2;border-top:1px solid var(--line);padding-top:18px;color:var(--muted);font-size:12px;line-height:1.58}
    .notes h4{margin-bottom:14px;color:var(--red);font-size:10px;line-height:1;letter-spacing:.22em;text-transform:uppercase}
    .notes ol{list-style:none;counter-reset:nt}.notes li{counter-increment:nt;position:relative;padding-left:34px;margin-bottom:10px}.notes li:before{content:counter(nt);position:absolute;left:0;top:0;color:var(--red);font-size:10px;letter-spacing:.14em}

    .file-note-shell{position:relative;padding:0 var(--pad);border-top:1px solid var(--black);border-bottom:1px solid var(--black);background:rgba(240,237,230,.48);backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);overflow:hidden}
    .file-note-shell:before{content:"";position:absolute;inset:0;pointer-events:none;background:linear-gradient(90deg,rgba(209,11,11,.045),transparent 34%,transparent 82%,rgba(10,10,9,.03));opacity:.72}
    .file-note{position:relative;z-index:3;width:100%;margin:0;color:var(--muted);font-size:11px;line-height:1.42;letter-spacing:.08em;text-transform:uppercase;display:block;border-left:1px solid rgba(10,10,9,.16);border-right:1px solid rgba(10,10,9,.16)}
    .file-note__row{display:grid;grid-template-columns:minmax(170px,.78fr) repeat(5,minmax(0,1fr)) auto;align-items:stretch;padding:0}
    .file-note__row+.file-note__row{border-top:1px solid rgba(10,10,9,.16)}
    .file-note__row--editorial{grid-template-columns:minmax(0,1.4fr) minmax(0,1.8fr) minmax(0,1fr)}
    .file-note__head,.file-note__cell,.file-note__actions{padding:18px 18px;border-right:1px solid rgba(10,10,9,.16);min-width:0}
    .file-note__row > :last-child{border-right:0}
    .file-note__head{display:grid;align-content:start;gap:7px;color:var(--faint);font-size:10px;line-height:1.25;letter-spacing:.16em;background:rgba(240,237,230,.18)}
    .file-note__head:before{display:none}
    .file-note__head strong{color:var(--red);font-weight:700;line-height:1.18}.file-note__head span{color:rgba(10,10,9,.46);white-space:normal}
    .file-note__cell{display:flex;flex-direction:column;gap:9px;background:rgba(240,237,230,.24)}
    .file-note__label{display:block;color:var(--red);font-size:9px;line-height:1;letter-spacing:.18em;white-space:nowrap}
    .file-note__value{display:block;color:var(--black);font-size:12px;line-height:1.5;letter-spacing:0;text-transform:none;overflow-wrap:anywhere}
    .file-note__value.small{font-size:10px;line-height:1.42;letter-spacing:.05em;text-transform:uppercase;color:var(--muted)}
    .file-note__actions{display:flex;flex-direction:column;gap:10px;align-items:flex-start;justify-content:flex-start;white-space:nowrap;background:rgba(240,237,230,.18)}
    .file-note button{border:0;border-bottom:1px solid var(--red);background:transparent;color:var(--black);padding:0 0 2px;font:inherit;font-size:10px;line-height:1.2;letter-spacing:.16em;text-transform:uppercase;cursor:pointer}
    .file-note a{color:var(--red);font-weight:700}.file-note button:hover,.file-note a:hover{color:var(--red)}

    .related{padding:clamp(64px,10vh,128px) var(--pad) clamp(48px,6vh,80px);background:var(--white)}
    .related-inner{width:100%;max-width:none;margin:0}
    .related-head{display:grid;grid-template-columns:1fr auto;align-items:end;gap:24px;margin-bottom:24px}
    .related-title{margin:0!important;border:0!important;background:transparent!important;box-shadow:none!important;text-shadow:none!important;-webkit-text-stroke:0!important;font-family:var(--font-display)!important;color:var(--black);font-size:clamp(48px,6vw,82px);line-height:.9;letter-spacing:-.012em;font-weight:400;text-transform:uppercase}
    .related-meta{display:flex;flex-direction:column;gap:8px;text-align:right;font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted)}
    .related-meta .big{font-family:var(--font-display)!important;font-size:52px;color:var(--black);line-height:.9;letter-spacing:0;font-weight:400}
    .related-intro{max-width:var(--col);margin:0 0 48px;color:var(--muted);font-size:14px;line-height:1.58;font-style:italic}
    .rel-row{position:relative;display:grid;grid-template-columns:60px 100px 110px 1fr 80px 44px;gap:16px;align-items:center;overflow:hidden;padding:18px 10px 18px 0;border-top:1px solid var(--line)}
    .rel-row:first-of-type{border-top:1px solid var(--black)}
    .rel-row:last-child{border-bottom:1px solid var(--line)}
    .rel-row:before{content:"";position:absolute;left:-100%;top:0;bottom:0;width:100%;background:linear-gradient(90deg,transparent 0%,rgba(209,11,11,.10) 25%,rgba(209,11,11,.20) 100%);transition:left .55s var(--ease)}.rel-row:hover:before{left:0}.rel-row>*{position:relative;z-index:1}.rel-row .no{color:var(--red);font-weight:700;font-size:13px}.rel-row .date,.rel-row .rub,.rel-row .min{color:var(--muted);font-size:11px;letter-spacing:.14em;text-transform:uppercase}.rel-row .ttl{color:var(--black);font-weight:500;font-size:14px;line-height:1.35;transition:transform .35s var(--ease)}.rel-row .reason{display:block;margin-top:5px;color:var(--muted);font-weight:400;font-size:11px;line-height:1.45;letter-spacing:.02em;text-transform:none}.rel-row:hover .ttl{transform:translateX(10px)}.rel-row .min{text-align:right}.rel-row .go{text-align:center}.rel-row .go{display:flex;justify-content:center;align-items:center}.rel-triangle{display:inline-block;width:16px;height:16px;background:var(--red);clip-path:polygon(0 0,100% 50%,0 100%);transition:transform .35s var(--ease),opacity .25s var(--ease);opacity:.86}.rel-row:hover .rel-triangle{transform:translateX(3px);opacity:1}

    .pnav{display:grid;grid-template-columns:1fr 1px 1fr;border-top:1px solid var(--black);border-bottom:1px solid var(--black);background:var(--cream)}.pnav .divline{background:var(--line)}.pnav a{padding:clamp(28px,4vh,48px) var(--pad);display:flex;flex-direction:column;gap:8px;transition:background .35s var(--ease)}.pnav a:hover{background:var(--soft)}.pnav .dir{display:flex;gap:12px;align-items:center;color:var(--muted);font-size:11px;letter-spacing:.22em;text-transform:uppercase}.pnav .label{font-family:var(--font-display);color:var(--black);font-size:clamp(22px,2.4vw,32px);line-height:1.05;letter-spacing:-.005em;font-weight:400;text-transform:uppercase}.pnav .nx{text-align:right}.pnav .nx .dir{justify-content:flex-end}.pnav .small{color:var(--muted);font-size:11px;letter-spacing:.14em;text-transform:uppercase}



    /* FIELD LOCK v09 — article uses the same outer gutter as index on every breakpoint.
       Global --pad stays clamp(20px,4vw,56px) until the shared mobile breakpoint max-width:760px. */
    @media(max-width:980px){
      .file-note{border-left:0;border-right:0}
      .file-note__row,.file-note__row--editorial{grid-template-columns:1fr;border-top:1px solid rgba(10,10,9,.16)}
      .file-note__head,.file-note__cell,.file-note__actions{padding:16px;border-right:0;border-bottom:1px solid rgba(10,10,9,.16)}
      .file-note__actions{justify-content:flex-start}
    }

    @media(max-width:760px){
      :root{--pad:20px;--col:min(680px,calc(100vw - 40px))}
      #articleTop{padding-top:0}
      .issue-line{gap:8px;padding:12px var(--pad);font-size:10px}
      .hero-wrap{width:auto!important;padding:22px var(--pad) 34px!important}
      .article-kicker{margin-bottom:22px!important;font-size:10px}
      .h-title{font-size:clamp(64px,19vw,116px)}
      .cover-wrap{margin:0 var(--pad) clamp(10px,1.8vh,18px)}
      .cover{margin:0}
      .cover-caption{width:auto}
      .article{display:block;padding:56px var(--pad) 80px}
      .article>*{grid-column:auto}
      .p-marker:before{display:none}
      .dropcap{font-size:88px;margin:6px 12px 0 0}
      .pull{margin:clamp(40px,8vh,80px) calc(-1 * var(--pad));padding:clamp(40px,8vh,80px) var(--pad)}
      .pull blockquote{font-size:clamp(38px,11vw,64px)}
      .notes{display:block;padding:0 var(--pad) 44px}
      .notes-inner{grid-column:auto}
      .related-head{grid-template-columns:minmax(0,1fr) auto;align-items:end;gap:18px;margin-bottom:18px}
      .related-intro{margin-bottom:32px}
      .related-title{font-size:clamp(44px,12vw,72px);min-width:0}
      .related-meta{align-items:flex-end;justify-self:end;min-width:max-content}
      .related-meta .big{font-size:38px}
      .rel-row{grid-template-columns:48px 1fr 36px;padding-right:8px}
      .rel-row .date,.rel-row .rub,.rel-row .min{display:none}
      .pnav{grid-template-columns:1fr}
      .pnav .divline{height:1px}
      .pnav .nx{text-align:left}
      .pnav .nx .dir{justify-content:flex-start}
    }

    @media(max-width:560px){
      .cover-corner.tr,.cover-corner.br{display:none}
      .cover-pinlbl{left:22px;top:auto;bottom:48px}
      .cover-cross{left:50%;top:48%}
      .rel-row{grid-template-columns:1fr 36px;padding-right:8px}
      .rel-row .no{display:none}
      .tool-card p{font-size:12px}
    }

    /* ARTICLE FONT LOCK */
    .issue-line,.issue-line *,.article-kicker,.article-kicker *,.h-deck,.h-deck *,.h-byline,.h-byline *,.cover-caption,.article,.article *,.p,.p *,.brk,.brk *,.sig,.sig *,.notes,.notes *,.file-note,.file-note *,.related-intro,.related-meta,.related-meta *,.rel-row,.rel-row *,.pnav .dir,.pnav .dir *,.pnav .small,.pnav .small *{font-family:var(--font-ui)!important}
    .h-title,.h-title *,.dropcap,.pull blockquote,.pull blockquote .qtxt,.related-title,.related-meta .big,.pnav .label{font-family:var(--font-display)!important}
    /* v12 HARD KILL: no empty eyebrow field above article title */
    .article-mast,.article-mast *{box-sizing:border-box}
    .article-mast{min-height:0!important;height:auto!important}
    @media(max-width:760px){#articleTop{margin-top:-56px;padding-top:56px}}
    .hero-wrap{display:block!important;min-height:0!important;height:auto!important;padding-top:clamp(22px,3.8vh,42px)!important;padding-bottom:clamp(34px,5.2vh,62px)!important}
    .article-kicker{position:static!important;display:inline-flex!important;margin:0 0 clamp(28px,4.8vh,54px)!important;align-items:center!important}
    .h-title{margin-top:0!important}


    /* v13 HARD FIX: article rubric is not the global rubric card; no vertical field before title */
    .article-kicker{height:auto!important;min-height:0!important;align-items:center!important;margin-bottom:clamp(28px,4.8vh,54px)!important}
    .article-kicker__dot{position:static!important;align-self:center!important;display:inline-block!important;transform:none!important;margin:0!important}
    .article-kicker .article-rubric{display:inline!important;min-height:0!important;height:auto!important;padding:0!important;margin:0!important;border:0!important;background:transparent!important;line-height:1!important}
    .hero-wrap{padding-top:clamp(22px,3.8vh,42px)!important;padding-bottom:clamp(34px,5.2vh,62px)!important}
    .h-title{margin-top:0!important;margin-bottom:clamp(18px,2.6vh,32px)!important}
    @media(max-width:760px){.hero-wrap{padding-top:28px!important;padding-bottom:42px!important}.article-kicker{margin-bottom:26px!important}}


    /* v17 mobile fixes: pull quote stays inside gutter */
    @media(max-width:760px){
      .pull{justify-content:flex-start!important}
      .pull blockquote{width:100%!important;max-width:none!important;text-align:left!important;padding-left:.52em!important}
      .pull blockquote:before{left:0!important;top:-.08em!important;transform:none!important}
    }

    /* v20: archive-card edge rules + paragraph markers */
    @media(max-width:1100px){
      .p-marker:before{display:none!important}
    }

    @media(max-width:980px){
      .file-note__row:first-child{border-top:0!important}
      .file-note__row:first-child > :first-child{border-top:0!important}
      .file-note__row:first-child > :first-child{border-bottom:0!important}
      .file-note__row:last-child > :last-child{border-bottom:0!important}
    }

  
  </style>
  <main id="articleTop">

    <section class="article-mast" aria-label="Шапка материала">
      <div class="issue-line">
        <span class="no">{article.issue}</span>
        <span class="sep">·</span>
        <span class="meta">{article.dateDisplay}</span>
        <span class="read"><b>{article.readTime}</b></span>
      </div>

      <div class="hero-wrap">
        <div class="article-kicker"><span class="article-kicker__dot" aria-hidden="true"></span><span class="article-rubric">{article.rubrics.join(' / ')}</span></div>
        <h1 class="h-title"><span class="word">Соль</span> <span class="word">Земли</span></h1>
        <p class="h-deck">{article.excerpt}</p>
      </div>
    </section>

    <figure class="cover-wrap" aria-label="Обложка материала">
      <div class="cover"><img class="cover-img" src={article.heroImage} alt="" loading="eager" decoding="async" /></div>
      <figcaption class="cover-caption">р. Вайгай, Мадурай. 2026. Canon R8</figcaption>
    </figure>

    <article class="article" aria-label="Текст материала">
      <p class="p p-marker" data-mark="¶ 01"><span class="dropcap">П</span>оследние два месяца мой круг общения и основные small-shit-talk-собеседники — водители рикш и автобусов, повара, официанты, администраторы ночлежек, прачки, продавцы всего на свете — рабочая соль земли. Они не очень-то в курсе происходящего, слабовато знают Трампа /но знают, что миста Пути — биг мэн/, и проживают какую-то свою, параллельную простую сложную жизнь, в которой каждый день нужно ставить на стол самую элементарную копеечную еду. Их легко ругать за необразованность, несуразность, неаккуратность — почти все их прилагательные начинаются с «не». Можно осуждать за грязь и пятна на одежде, но помнить, что, зачастую, у них нет другой, кроме на них, что той.</p>
      <p class="p p-marker" data-mark="¶ 02">Здесь, в урбанизированных до полной несовместимости с жизнью городах и деревнях проживает очень, очень большая масса людей. Непредставимая, пока не увидишь. Все вместе они как-то умудряются каждый год нарулить себе то третью, то пятую экономику мира. При этом у каждого в отдельности — почти ничего. Совсем. Одни гражданские права.</p>
      <div class="pull"><blockquote><span class="qtxt">{article.thesis}</span></blockquote></div>
      <p class="p p-marker" data-mark="¶ 03">Индия вообще странная конструкция: бедность здесь индивидуальна, а мощь — коллективна. Кажется, мы такое уже где-то видели, да?</p>
      <div class="brk"><span class="line"></span><span class="num">§ II</span><span class="line"></span></div>
      <p class="p p-marker" data-mark="¶ 04">Плохая новость в том, что эта «параллельность» — кажущаяся. Именно бедноту всё текущее коснётся в самую первую очередь. Их оно с большой вероятностью совсем изведёт. Но пока жизнь тут кипит на всех уровнях. Очень красиво пузырится.</p>
      <p class="p p-marker" data-mark="¶ 05">Казалось бы, какое отношение всё это имеет к празднику восьмого марта? Никакого, в том-то и дело. О международном женском дне здесь даже и не слышали. Сегодня вся эта цветастая крикливая неряшливая толпа опять будет работать. Лениво, медленно, иногда старательно, но недолго и всё равно — плохо.</p>
      <p class="p p-marker" data-mark="¶ 06">Азия — наглядный пример теории, что делать хорошо вовсе не обязательно. Достаточно просто делать. Что-то да получится. 4.13 трлн $ ВВП, например.<a class="fn" href="#note-1">1</a></p>
      <div class="brk"><span class="line"></span><span class="num">§ III</span><span class="line"></span></div>
      <p class="p p-marker" data-mark="¶ 07">Сегодня, трясясь в прокуренном вагоне восьмой час в видавшем лучшие времена муниципальном рейсовом автобусе Мадурай — Мадрас,<a class="fn" href="#note-2">2</a> я полуеду-полусплю и радуюсь. Хотя до конца маршрута ещё далеко, я всё равно вернусь домой. К самым красивым женщинам Мира. Таких больше нет нигде. И не будет.</p>
      <p class="p p-marker" data-mark="¶ 08">С Праздником, Милые!</p>
      <p class="sig"><span class="sig-skull" aria-hidden="true"></span><span class="dash">—</span><span class="name">kolbovskiy.club</span></p>
    </article>

    <section class="notes" aria-label="Примечания">
      <div class="notes-inner">
        <h4>Примечания</h4>
        <ol>
          <li id="note-1">Цифра ВВП оставлена как авторская рабочая оценка масштаба, а не как статистическая таблица.</li>
          <li id="note-2">Мадрас — старое название Ченнаи; в тексте сохранено как интонация маршрута и полевой речи.</li>
          <li>small-shit-talk — авторская формула для коротких бытовых разговоров в дороге.</li>
        </ol>
      </div>
    </section>

    <div class="file-note-shell">
      <aside class="file-note" aria-label="Архивная карточка">
        <div class="file-note__row">
          <div class="file-note__head"><strong>{article.issue} / {article.rubrics[0]}</strong><span>{article.title}</span></div>
          <div class="file-note__cell"><span class="file-note__label">Дата</span><span class="file-note__value small">{article.dateLong}</span></div>
          <div class="file-note__cell"><span class="file-note__label">Время</span><span class="file-note__value small">{article.timeLabel}</span></div>
          <div class="file-note__cell"><span class="file-note__label">Рубрики</span><span class="file-note__value small">{article.rubrics.join(' / ')}</span></div>
          <div class="file-note__cell"><span class="file-note__label">Время прочтения</span><span class="file-note__value small">{article.readTime}</span></div>
          <div class="file-note__cell"><span class="file-note__label">Исходник</span><span class="file-note__value small">{article.source}</span></div>
          <div class="file-note__actions"><a href={article.telegramUrl} target="_blank" rel="noopener">Telegram →</a><button type="button" id="copyLinkBtn">Поделиться</button></div>
        </div>
        <div class="file-note__row file-note__row--editorial">
          <div class="file-note__cell"><span class="file-note__label">Тезис</span><span class="file-note__value">{article.thesis}</span></div>
          <div class="file-note__cell"><span class="file-note__label">Темы</span><span class="file-note__value small">{article.topics.join(' / ')}</span></div>
          <div class="file-note__cell"><span class="file-note__label">Статус</span><span class="file-note__value small">{article.status}</span></div>
        </div>
      </aside>
    </div>

    <section class="related" aria-label="Связанное">
      <div class="related-inner">
        <div class="related-head"><h2 class="related-title">Связанное</h2><div class="related-meta"><span>связанных материалов</span><span class="big">{String(article.related.length).padStart(2, '0')}</span></div></div>
        <p class="related-intro">Соседние материалы архива: по теме, рубрике, месту или внутренней связи.</p>
        {article.related.map((item) => (
          <a class="rel-row" href={item.href}>
            <span class="no">{item.issue}</span>
            <span class="date">{item.date}</span>
            <span class="rub">{item.rubric}</span>
            <span class="ttl">{item.title}<span class="reason">{item.reason}</span></span>
            <span class="min">{item.readTime}</span>
            <span class="go"><span class="rel-triangle" aria-hidden="true"></span></span>
          </a>
        ))}
      </div>
    </section>

    <nav class="pnav" aria-label="Навигация по материалам">
      <a class="prev" href="/archive/"><span class="dir"><span>←</span> Назад</span><span class="label">В архив</span><span class="small">полный реестр · годы · поиск</span></a>
      <div class="divline"></div>
      <a class="nx" href="/rubrics/#mlrm"><span class="dir">К рубрике <span>→</span></span><span class="label">МЛРМ</span><span class="small">сложные системы · рынки · поведение · Реальный мир</span></a>
    </nav>
</main>
</SiteLayout>
