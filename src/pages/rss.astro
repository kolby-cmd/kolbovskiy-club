---
import SiteLayout from '../layouts/SiteLayout.astro';
import { buildJsonLdGraph, KOLBOVSKIY_CLUB_WEBSITE_ID, KOLBOVSKIY_PERSON_ID } from '../data/siteEntity';

const siteUrl = 'https://kolbovskiy.club';
const title = 'RSS — kolbovskiy.club';
const description = 'RSS-лента kolbovskiy.club: машинная подписка на новые материалы архива.';
const canonical = `${siteUrl}/rss/`;
const feedUrl = `${siteUrl}/rss.xml`;

const jsonLd = buildJsonLdGraph({
  '@type': 'WebPage',
  '@id': `${canonical}#webpage`,
  name: title,
  description,
  url: canonical,
  inLanguage: 'ru',
  isPartOf: { '@id': KOLBOVSKIY_CLUB_WEBSITE_ID },
  author: { '@id': KOLBOVSKIY_PERSON_ID },
  publisher: { '@id': KOLBOVSKIY_PERSON_ID },
  about: {
    '@type': 'DataFeed',
    '@id': `${feedUrl}#feed`,
    name: 'kolbovskiy.club RSS',
    url: feedUrl,
    encodingFormat: 'application/rss+xml'
  }
});
---
<SiteLayout title={title} description={description} canonical={canonical} current="" jsonLd={jsonLd}>
  <style slot="pageStyles" is:global>
    .rss-page .plain-title{
      font-size:clamp(72px,12vw,164px);
    }

    .rss-actions{
      display:flex;
      flex-wrap:wrap;
      gap:10px 18px;
      margin-top:clamp(28px,4vh,44px);
      font-family:var(--font-ui);
    }

    .rss-action{
      border:0;
      background:transparent;
      padding:0;
      color:var(--red);
      font-family:var(--font-ui);
      font-size:10px;
      line-height:1.2;
      letter-spacing:.16em;
      text-transform:uppercase;
      text-decoration:none;
      cursor:pointer;
      transition:color var(--motion-ui) var(--ease),opacity var(--motion-ui) var(--ease);
    }

    .rss-action:hover{
      color:var(--black);
    }

    .rss-action:focus-visible{
      outline:1px solid var(--red);
      outline-offset:4px;
    }

    .rss-note{
      margin-top:clamp(24px,3.5vh,38px);
      color:var(--gray);
      font-family:var(--font-ui);
      font-size:12px;
      line-height:1.6;
    }
  </style>

  <main class="plain-page rss-page">
    <section class="plain-shell">
      <div class="plain-kicker"><span>служебный канал</span><span>RSS / XML</span></div>
      <h1 class="plain-title">RSS</h1>

      <div class="plain-text">
        <p>RSS — машинная лента kolbovskiy.club для подписки через RSS-читалки, агрегаторы и внешние инструменты.</p>
      </div>

      <div class="rss-actions" aria-label="Действия RSS">
        <button class="rss-action" type="button" data-copy-rss="[скопировать rss ссылку]" data-copied-rss="[ссылка скопирована]">[скопировать rss ссылку]</button>
        <a class="rss-action" href="/archive/">[в архив]</a>
      </div>

      <p class="rss-note">Чтобы подписаться, скопируйте RSS-ссылку и добавьте её в свою RSS-читалку.</p>
    </section>
  </main>

  <script is:inline>
    (() => {
      const button = document.querySelector('[data-copy-rss]');
      if (!button) return;

      const feedUrl = 'https://kolbovskiy.club/rss.xml';
      const initial = button.getAttribute('data-copy-rss') || '[скопировать rss ссылку]';
      const copied = button.getAttribute('data-copied-rss') || '[ссылка скопирована]';

      async function copyText(value){
        if (navigator.clipboard && window.isSecureContext) {
          await navigator.clipboard.writeText(value);
          return true;
        }

        const area = document.createElement('textarea');
        area.value = value;
        area.setAttribute('readonly', '');
        area.style.position = 'fixed';
        area.style.left = '-9999px';
        document.body.appendChild(area);
        area.select();
        const ok = document.execCommand('copy');
        document.body.removeChild(area);
        return ok;
      }

      button.addEventListener('click', async () => {
        try {
          await copyText(feedUrl);
          button.textContent = copied;
          window.setTimeout(() => {
            button.textContent = initial;
          }, 1600);
        } catch {
          button.textContent = '[не скопировалось]';
          window.setTimeout(() => {
            button.textContent = initial;
          }, 1600);
        }
      });
    })();
  </script>
</SiteLayout>
