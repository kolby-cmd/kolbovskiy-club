---
import SiteLayout from '../layouts/SiteLayout.astro';
import { buildJsonLdGraph, KOLBOVSKIY_CLUB_WEBSITE_ID, KOLBOVSKIY_PERSON_ID } from '../data/siteEntity';

const siteUrl = 'https://kolbovskiy.club';
const title = 'RSS — kolbovskiy.club';
const description = 'RSS-лента kolbovskiy.club: подписка на новые материалы.';
const canonical = `${siteUrl}/rss/`;
const feedUrl = `${siteUrl}/rss.xml`;

const jsonLd = buildJsonLdGraph({
  '@type': 'WebPage',
  '@id': `${canonical}#webpage`,
  name: title,
  description,
  url: canonical,
  inLanguage: 'ru',
  isPartOf: { '@id': KOLBOVSKIY_CLUB_WEBSITE_ID },
  author: { '@id': KOLBOVSKIY_PERSON_ID },
  publisher: { '@id': KOLBOVSKIY_PERSON_ID },
  about: {
    '@type': 'DataFeed',
    '@id': `${feedUrl}#feed`,
    name: 'kolbovskiy.club RSS',
    url: feedUrl,
    encodingFormat: 'application/rss+xml'
  }
});
---
<SiteLayout title={title} description={description} canonical={canonical} current="" jsonLd={jsonLd}>
  <style slot="pageStyles" is:global>
.rss-actions{
      display:flex;
      flex-wrap:wrap;
      gap:10px 18px;
      margin-top:clamp(28px,4vh,44px);
      font-family:var(--font-ui);
    }

    .rss-command{
      display:inline;
      border:0;
      background:transparent;
      padding:0;
      color:var(--red);
      font-family:var(--font-ui);
      font-size:10px;
      line-height:1.2;
      letter-spacing:.16em;
      text-transform:uppercase;
      text-decoration:none;
      cursor:pointer;
      transition:color var(--motion-ui) var(--ease), opacity var(--motion-ui) var(--ease);
    }

    .rss-command:hover{
      color:var(--black);
    }

    .rss-command:focus-visible{
      outline:1px solid var(--red);
      outline-offset:4px;
    }

    .rss-note{
      max-width:720px;
      margin-top:clamp(24px,3.5vh,38px);
      color:var(--gray);
      font-family:var(--font-ui);
      font-size:12px;
      line-height:1.6;
    }
  </style>

  <main class="plain-page rss-page">
    <section class="plain-shell">
      <div class="plain-kicker"><span class="dot dot-pulse"></span><span>KOLBOVSKIY.CLUB · RSS / XML</span></div>
      <h1 class="plain-title">RSS</h1>

      <div class="plain-text">
        <p>RSS — машинная лента kolbovskiy.club для подписки через RSS-читалки, агрегаторы и внешние инструменты.</p>
      </div>

      <div class="rss-actions" aria-label="Действия RSS">
        <button class="rss-command" type="button" data-copy-rss>[скопировать rss ссылку]</button>
        <a class="rss-command" href="/archive/">[в архив]</a>
      </div>

      <p class="rss-note">Чтобы подписаться, скопируйте RSS-ссылку и добавьте её в свою RSS-читалку.</p>
    </section>
  </main>

  <script is:inline>
    (() => {
      const button = document.querySelector('[data-copy-rss]');
      if (!button) return;

      const feedUrl = 'https://kolbovskiy.club/rss.xml';
      const initial = '[скопировать rss ссылку]';
      const copied = '[ссылка скопирована]';
      const failed = '[не скопировалось]';

      async function copyText(value){
        if (navigator.clipboard && window.isSecureContext) {
          await navigator.clipboard.writeText(value);
          return;
        }

        const area = document.createElement('textarea');
        area.value = value;
        area.setAttribute('readonly', '');
        area.style.position = 'fixed';
        area.style.left = '-9999px';
        document.body.appendChild(area);
        area.select();
        document.execCommand('copy');
        document.body.removeChild(area);
      }

      button.addEventListener('click', async () => {
        try {
          await copyText(feedUrl);
          button.textContent = copied;
        } catch {
          button.textContent = failed;
        }

        window.setTimeout(() => {
          button.textContent = initial;
        }, 1600);
      });
    })();
  </script>
</SiteLayout>
