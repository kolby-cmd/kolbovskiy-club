---
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { articles } from '../data/articles';

const {
  title = 'kolbovskiy.club',
  description = 'Частное авторское медиа / публичный архив.',
  canonical = 'https://kolbovskiy.club/',
  ogType = 'website',
  current = '',
  telegramUrl = 'https://t.me/klb_clb',
  jsonLd = null,
  ogImage = null
} = Astro.props;

const SITE_URL = 'https://kolbovskiy.club';
const DEFAULT_OG_IMAGE = '/og/kolbovskiy-club.jpg';
const absoluteUrl = (value: string | null | undefined) => {
  if (!value) return null;
  try {
    return new URL(value, SITE_URL).toString();
  } catch {
    return null;
  }
};
const canonicalUrl = absoluteUrl(canonical) ?? SITE_URL;
const metaOgImage = absoluteUrl(ogImage ?? DEFAULT_OG_IMAGE);

const stripHtml = (value = '') => String(value)
  .replace(/<br\s*\/?>/gi, ' ')
  .replace(/<[^>]+>/g, ' ')
  .replace(/\s+/g, ' ')
  .trim();

const searchIndex = articles
  .filter(Boolean)
  .map((article) => {
    const deck = stripHtml(article.deckHtml);
    const rubrics = article.rubrics ?? [];
    const topics = article.topics ?? [];
    const body = Array.isArray(article.body) ? article.body.map(stripHtml).join(' ') : '';

    return {
      issue: article.issue,
      rubric: rubrics[0]?.replace('#', '') ?? 'архив',
      rubrics: rubrics.map((item) => item.replace('#', '')).join(' / '),
      title: article.title,
      deck,
      label: deck ? `${article.title} / ${deck}` : article.title,
      href: `/txt/${article.slug}/`,
      haystack: [
        article.issue,
        article.title,
        deck,
        article.description,
        article.excerpt,
        article.thesis,
        rubrics.join(' '),
        topics.join(' '),
        body
      ].filter(Boolean).join(' ').toLowerCase()
    };
  });

const searchSuggestions = searchIndex.slice(0, 5);
