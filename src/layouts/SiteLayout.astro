---
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { articles } from '../data/articles';

const {
  title = 'kolbovskiy.club',
  description = 'Частное авторское медиа / публичный архив.',
  canonical = 'https://kolbovskiy.club/',
  ogType = 'website',
  current = '',
  telegramUrl = 'https://t.me/klb_clb',
  jsonLd = null,
  ogImage = null
} = Astro.props;

const stripHtml = (value = '') => String(value)
  .replace(/<br\s*\/?>/gi, ' ')
  .replace(/<[^>]+>/g, ' ')
  .replace(/\s+/g, ' ')
  .trim();

const searchIndex = articles
  .filter(Boolean)
  .map((article) => {
    const deck = stripHtml(article.deckHtml);
    const rubrics = article.rubrics ?? [];
    const topics = article.topics ?? [];
    const body = Array.isArray(article.body) ? article.body.map(stripHtml).join(' ') : '';

    return {
      issue: article.issue,
      rubric: rubrics[0]?.replace('#', '') ?? 'архив',
      rubrics: rubrics.map((item) => item.replace('#', '')).join(' / '),
      title: article.title,
      deck,
      label: deck ? `${article.title} / ${deck}` : article.title,
      href: `/txt/${article.slug}/`,
      haystack: [
        article.issue,
        article.title,
        deck,
        article.description,
        article.excerpt,
        article.thesis,
        rubrics.join(' '),
        topics.join(' '),
        body
      ].filter(Boolean).join(' ').toLowerCase()
    };
  });

const searchSuggestions = searchIndex.slice(0, 5);
---
<!doctype html>
<html lang="ru">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#F0EDE6" />
  <link rel="icon" type="image/png" href="/apple-touch-icon.png" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
<meta property="og:type" content={ogType} />
  <meta property="og:site_name" content="kolbovskiy.club" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  {ogImage ? <meta property="og:image" content={ogImage} /> : null}
  <meta name="twitter:card" content="summary_large_image" />
  {ogImage ? <meta name="twitter:image" content={ogImage} /> : null}
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  {jsonLd ? <script type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script> : null}
  <style is:global>
    @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,400;0,500;0,700;1,400;1,500&display=swap');
    @font-face{font-family:DAMN;src:url('/fonts/DAMN.ttf') format('truetype');font-weight:400;font-style:normal;font-display:block;font-synthesis:none}

    :root{
      --red:#d10b0b;
      --white:#F0EDE6;
      --black:#0A0A09;
      --cream:#EBE6D9;
      --soft:#E6E2D6;
      --muted:rgba(10,10,9,.58);
      --faint:rgba(10,10,9,.36);
      --gray:rgba(10,10,9,.55);
      --gray2:rgba(10,10,9,.34);
      --line:rgba(10,10,9,.16);
      --line-strong:rgba(10,10,9,.34);
      --font-display:'DAMN','JetBrains Mono',sans-serif;
      --font-ui:'JetBrains Mono','Cascadia Mono',Consolas,'Courier New',ui-monospace,monospace;
      --pad:clamp(20px,4vw,56px);
      --col:min(680px,calc(100vw - var(--pad)*2));
      --ease:cubic-bezier(.16,1,.3,1);
      --motion-instant:.12s;
      --motion-fast:.18s;
      --motion-ui:.25s;
      --motion-hover:.35s;
      --motion-panel:.52s;
      --motion-sweep:.55s;
      --motion-pulse:1.8s;
      --motion-rail:2.4s;
      --motion-ticker:42s;
      --motion-word:1s;
      --motion-wave-a:24s;
      --motion-wave-b:26s;
    }

    *{box-sizing:border-box;margin:0;padding:0}
    html{background:var(--white);color:var(--black);font-family:var(--font-ui);-webkit-font-smoothing:antialiased;text-rendering:geometricPrecision;font-synthesis:none;text-rendering:optimizeLegibility;scroll-behavior:smooth}
    body{min-height:100vh;background:var(--white);overflow-x:hidden;font-family:var(--font-ui)}
    main{position:relative;z-index:2;background:var(--white)}
    a{color:inherit;text-decoration:none}
    button,input,textarea,select{font-family:var(--font-ui);color:inherit}
    button{font:inherit;color:inherit}
    ::selection{background:var(--red);color:var(--white)}
    .red{color:var(--red)}
    .dim{color:var(--muted)}
    .dot{display:inline-block;width:7px;height:7px;border-radius:50%;background:var(--red);vertical-align:middle;flex:0 0 auto}
    .dot-pulse{animation:pulse var(--motion-pulse) infinite}
    @keyframes pulse{0%,100%{transform:scale(1);opacity:1}50%{transform:scale(1.32);opacity:.55}}
    .arrow-icon{display:inline-block;width:42px;height:12px;background:currentColor;transition:transform var(--motion-hover) var(--ease);-webkit-mask:url('/assets/Arrow.png') center/contain no-repeat;mask:url('/assets/Arrow.png') center/contain no-repeat}

    .plain-page{
      --plain-header:58px;
      margin-top:calc(-1 * var(--plain-header));
      min-height:100svh;
      display:flex;
      flex-direction:column;
      justify-content:flex-start;
      background:var(--white);
      padding:calc(var(--plain-header) + clamp(70px,8.5vh,110px)) var(--pad) clamp(96px,14vh,160px);
    }
    .plain-shell{
      width:min(720px,calc(100vw - var(--pad)*2));
      margin:0 auto;
    }
    .plain-kicker{
      display:flex;
      align-items:center;
      gap:14px;
      margin:0 0 clamp(24px,4vh,44px);
      color:var(--red);
      font-size:11px;
      line-height:1;
      letter-spacing:.18em;
      text-transform:uppercase;
    }
    .plain-title{
      margin:0 0 clamp(34px,5vh,58px);
      font-family:var(--font-display)!important;
      color:var(--red);
      font-size:clamp(64px,9vw,132px);
      line-height:.86;
      letter-spacing:-.015em;
      text-transform:uppercase;
      font-weight:400;
    }
    .plain-text{
      color:var(--black);
      font-size:clamp(16px,1.15vw,18px);
      line-height:1.72;
      text-wrap:pretty;
    }
    .plain-text p+p{margin-top:1.2em}

    .foot{position:sticky;bottom:0;z-index:0;background:var(--black);color:var(--white);min-height:0;padding:clamp(46px,6.4vh,74px) var(--pad) 0;overflow:hidden}
    .foot-inner{width:100%;max-width:none;margin:0 auto}
    .foot-title{font-family:var(--font-display);font-weight:400;color:var(--white);font-size:clamp(44px,6.2vw,104px);line-height:.84;letter-spacing:-.014em;text-transform:none;text-shadow:none;-webkit-text-stroke:0;margin:0 0 18px;max-width:none}
    .foot-cta{display:inline-flex;align-items:center;gap:14px;color:var(--red);font-weight:700;font-size:13px;letter-spacing:.08em;text-transform:uppercase;margin:0 0 clamp(30px,4vh,44px)}
    .foot-cta:hover .arrow-icon{transform:translateX(10px)}
    .foot-meta{display:grid;grid-template-columns:minmax(0,1fr) auto;gap:32px;align-items:end;width:100%;padding:0 0 24px}
    .foot-credits{display:grid;gap:9px;color:rgba(240,237,230,.54);font-size:11px;line-height:1.55;letter-spacing:.08em;text-transform:uppercase;font-weight:500}
    .foot-credits a{color:rgba(240,237,230,.78);text-decoration:none;border-bottom:1px solid rgba(240,237,230,.28);transition:color var(--motion-ui) var(--ease),border-color var(--motion-ui) var(--ease)}
    .foot-credits a:hover{color:var(--red);border-color:var(--red)}
    .age-mark{justify-self:end;align-self:end;color:var(--white);font-weight:700;font-size:clamp(16px,1.4vw,22px);line-height:1;letter-spacing:.04em;text-transform:uppercase}
    .foot-bottom{display:grid;grid-template-columns:1fr auto;gap:24px;align-items:center;width:100%;height:58px;border-top:1px solid rgba(240,237,230,.18);font-size:11px;letter-spacing:.08em;text-transform:uppercase;font-weight:500;color:rgba(240,237,230,.54)}
    .foot-bottom-links{display:none}
    .foot-bottom a{color:rgba(240,237,230,.72);text-decoration:none;transition:color var(--motion-ui) var(--ease)}
    .foot-bottom a:hover{color:var(--red)}

    body,button,input,textarea,select,.site-header,.site-header *,.foot,.foot *,.search-panel,.search-panel *{font-family:var(--font-ui)!important}
    .foot-title,.mobile-panel nav a{font-family:var(--font-display)!important;text-shadow:none!important;-webkit-text-stroke:0!important;filter:none!important;-webkit-font-smoothing:antialiased}

    @media(max-width:760px){.plain-page{--plain-header:56px;padding:calc(var(--plain-header) + 58px) var(--pad) 88px}.plain-title{font-size:clamp(54px,17vw,96px);margin-bottom:30px}.plain-kicker{font-size:10px;letter-spacing:.14em;margin-bottom:24px}.foot{min-height:0;padding:44px var(--pad) 0}.foot-title{font-size:clamp(48px,15vw,86px);max-width:none;margin-bottom:18px}.foot-cta{margin-bottom:30px}.foot-meta{grid-template-columns:1fr auto;gap:22px;padding-bottom:22px}.foot-credits{font-size:10px}.age-mark{font-size:18px}.foot-bottom{grid-template-columns:1fr auto;gap:24px;height:auto;padding:16px 0}.foot-bottom-links{display:none}}
      html,body{background:var(--white)}
  </style>
  <slot name="pageStyles" />
</head>
<body>
  <SiteHeader current={current} telegramUrl={telegramUrl} />
  <aside class="search-panel" id="searchPanel" aria-label="Поиск по публикациям">
    <div class="search-box">
      <div class="search-head"><span>Поиск по публикациям</span><button class="search-close" id="searchClose" type="button" aria-label="Закрыть поиск"><span class="search-close-icon" aria-hidden="true"></span></button></div>
      <input class="search-input" id="searchInput" type="search" placeholder="" aria-label="Поиск по публикациям" />
      <div class="search-results" id="searchResults">
        {searchSuggestions.map((item) => (
          <a class="search-result" href={item.href}>
            <span>{item.issue}</span>
            <span class="rub">{item.rubric}</span>
            <b>{item.label}</b>
            <span class="go"><span class="search-triangle" aria-hidden="true"></span></span>
          </a>
        ))}
      </div>
      <script type="application/json" id="searchIndex" is:inline set:html={JSON.stringify(searchIndex)}></script>
    </div>
  </aside>
  <div class="progress"><div class="progress-fill" id="progressFill"></div></div>
  <slot />
  <SiteFooter telegramUrl={telegramUrl} />
  <script is:inline>
    (function(){
      const body = document.body;
      const menuBtn = document.getElementById('menuToggle');
      const menuLinks = document.querySelectorAll('.mobile-panel a');
      const searchOpen = document.getElementById('searchOpen');
      const mobileSearchOpen = document.getElementById('mobileSearchOpen');
      const searchClose = document.getElementById('searchClose');
      const searchInput = document.getElementById('searchInput');
      const searchResults = document.getElementById('searchResults');
      const searchIndexNode = document.getElementById('searchIndex');
      const fill = document.getElementById('progressFill');
      let searchItems = [];

      try {
        searchItems = searchIndexNode ? JSON.parse(searchIndexNode.textContent || '[]') : [];
      } catch {
        searchItems = [];
      }

      function escapeHtml(value){
        return String(value || '')
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#039;');
      }

      function normalizeSearch(value){
        return String(value || '').trim().toLowerCase().replace(/ё/g, 'е');
      }

      function renderSearch(query = ''){
        if(!searchResults) return;

        const normalized = normalizeSearch(query);
        const pool = normalized
          ? searchItems.filter(item => normalizeSearch(item.haystack).includes(normalized)).slice(0, 8)
          : searchItems.slice(0, 5);

        if(!pool.length){
          searchResults.innerHTML = '<div class="search-empty">ничего не найдено · попробуй другой сигнал</div>';
          return;
        }

        searchResults.innerHTML = pool.map(item => `
          <a class="search-result" href="${escapeHtml(item.href)}">
            <span>${escapeHtml(item.issue)}</span>
            <span class="rub">${escapeHtml(item.rubric)}</span>
            <b>${escapeHtml(item.label)}</b>
            <span class="go"><span class="search-triangle" aria-hidden="true"></span></span>
          </a>
        `).join('');
      }
      let navRevealTimer;

      function closeMenu(){ body.classList.remove('menu-open'); }
      function openSearch(event){
        if(event) event.preventDefault();
        closeMenu();
        body.classList.add('search-open');
        renderSearch(searchInput ? searchInput.value : '');
        window.setTimeout(() => searchInput && searchInput.focus(), 60);
      }
      function closeSearch(){ body.classList.remove('search-open'); }
      function hideNavWhileScrolling(){
        if(window.innerWidth <= 760){
          body.classList.remove('nav-is-scrolling');
          body.classList.remove('nav-row-hidden');
          return;
        }
        body.classList.add('nav-is-scrolling');
        window.clearTimeout(navRevealTimer);
        navRevealTimer = window.setTimeout(() => {
          body.classList.remove('nav-is-scrolling');
          body.classList.remove('nav-row-hidden');
        }, 620);
      }
      function updateProgress(){
        if(!fill) return;
        const root = document.documentElement;
        const max = Math.max(root.scrollHeight - window.innerHeight, 1);
        const passed = Math.min(Math.max(window.scrollY || root.scrollTop || 0, 0), max);
        fill.style.width = `${(passed / max) * 100}%`;
      }
      ['scroll','wheel','touchmove'].forEach(eventName => {
        window.addEventListener(eventName, () => {
          hideNavWhileScrolling();
          updateProgress();
        }, { passive:true });
      });
      window.addEventListener('keydown', event => {
        if(['ArrowDown','ArrowUp','PageDown','PageUp','Home','End',' '].includes(event.key)) hideNavWhileScrolling();
        if(event.key === 'Escape'){
          closeMenu();
          closeSearch();
        }
      });
      window.addEventListener('resize', () => {
        if(window.innerWidth <= 760){
          body.classList.remove('nav-is-scrolling');
          body.classList.remove('nav-row-hidden');
        }
        updateProgress();
      });
      if(menuBtn) menuBtn.addEventListener('click', () => body.classList.toggle('menu-open'));
      menuLinks.forEach(link => link.addEventListener('click', closeMenu));
      if(searchOpen) searchOpen.addEventListener('click', openSearch);
      if(mobileSearchOpen) mobileSearchOpen.addEventListener('click', openSearch);
      if(searchClose) searchClose.addEventListener('click', closeSearch);
      if(searchInput) searchInput.addEventListener('input', () => renderSearch(searchInput.value));
      renderSearch('');
      updateProgress();
    })();
  </script>
</body>
</html>
